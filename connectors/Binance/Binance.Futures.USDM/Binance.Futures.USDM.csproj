<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <Configurations>Debug;Release;Release-PROFILE</Configurations>
        <Platforms>AnyCPU</Platforms>
        <AssemblyName>QuantInfra.Connectors.Binance.Futures.Usdm</AssemblyName>
        <RootNamespace>QuantInfra.Connectors.Binance.Futures.Usdm</RootNamespace>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Release-PROFILE' ">
      <Optimize Condition=" '$(Optimize)' == '' ">true</Optimize>
      <DefineConstants>TRACE;PROFILE</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.6" />
      <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="9.0.6" />
      <PackageReference Include="prometheus-net" Version="8.2.1" />
      <PackageReference Include="Quartz" Version="3.18.1" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\..\services\MarketData\MarketData.csproj" />
      <ProjectReference Include="..\..\Connectors.Common.Crypthography\Connectors.Common.Crypthography.csproj" />
      <ProjectReference Include="..\..\Connectors.Common\Connectors.Common.csproj" />
      <ProjectReference Include="..\..\GenericWebSocketClient\GenericWebSocketClient.csproj" />
      <ProjectReference Include="..\Binance.Common\Binance.Common.csproj" />
    </ItemGroup>

</Project>
