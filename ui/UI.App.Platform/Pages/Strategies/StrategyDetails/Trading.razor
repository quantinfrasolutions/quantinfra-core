@page "/strategies/{StrategyId:int}/trading"
@using UI.SharedComponents.Accounts.Trading

@layout StrategyBase

@if (StrategyBase?.Strategy != null)
{
    <AccountTradingView Account=@StrategyBase.Strategy.Account />
}

@code {
    private bool _positionsExpanded = true, _ordersExpanded = true;
    
    [Parameter] public int StrategyId { get; set; }
    [CascadingParameter] public StrategyBase? StrategyBase { get; set; }

    protected override void OnInitialized()
    {
        StrategyBase!.Id = StrategyId;
        StrategyBase.Path = "trading";
    }
    

}