@using UI.SharedComponents.Accounts.SharePrice

@page "/accounts/{AccountId:int}/share-price"

@layout AccountBase

@if (AccountBase?.Account?.EnableSharePriceTracking == true)
{
    <AccountSharePriceHistory AccountId=@AccountBase.Account.AccountId />
}

@code {
    [Parameter] public int AccountId { get; set; }
    
    [CascadingParameter] public AccountBase? AccountBase { get; set; }

    protected override void OnInitialized()
    {
        AccountBase.Id = AccountId;
        AccountBase.Path = "share-price";
    }
}