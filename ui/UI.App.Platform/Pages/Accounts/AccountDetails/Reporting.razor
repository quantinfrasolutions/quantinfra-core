@using UI.SharedComponents.Base
@using UI.SharedComponents.Components
@inherits LayoutComponentBase

@page "/accounts/{AccountId:int}/reporting"

@layout AccountBase

<NavigationTabsView BasePath=@($"/accounts/{AccountBase?.Account?.AccountId}/reporting")
                    Tabs=@_tabs
                    SelectedTabPath=@Path
                    DisplayAsList=@string.IsNullOrEmpty(Path)>
    <ChildContent>
        <CascadingValue Value=@this>
            @Body
        </CascadingValue>
    </ChildContent>
</NavigationTabsView>

@code {
    [Parameter] public int AccountId { get; set; }
    [CascadingParameter] public AccountBase? AccountBase { get; set; }

    private string _path;
    public string Path
    {
        get => _path;
        set
        {
            _path = value;
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        AccountBase.Path = "reporting";
        
        if (string.IsNullOrEmpty(Path)) AccountBase.Id = AccountId; // otherwise, the child component will set the ID
    }

    private List<NavigationTabsItem> _tabs = new()
    {
        new() { Text = "Trades", Path = "trade-history" },
        new() { Text = "Positions history", Path = "positions-history" },
        new() { Text = "Orders history", Path = "orders-history" },
        new() { Text = "Balance operations", Path = "balance-operations-history" },
        new() { Text = "Share price and investment", Path = "share-price-history" },
    };
}