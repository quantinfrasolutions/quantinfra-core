@page "/accounts/{AccountId:int}/reporting/share-price-history"
@using QuantInfra.Common.Interfaces.Api.Accounts

@layout Reporting

<UI.SharedComponents.Components.Accounts.SharePriceHistory SingleAccount="true" Filter=@(new SharePriceHistoryFilter { AccountId = AccountId }) />

@code {
    [Parameter] public int AccountId { get; set; }
    
    [CascadingParameter] public AccountBase AccountBase { get; set; }
    [CascadingParameter] public Reporting Reporting { get; set; }

    protected override void OnInitialized()
    {
        AccountBase.Id = AccountId;
        Reporting.Path = "share-price-history";
    }
}