
@page "/accounts/{AccountId:int}/reporting/balance-operations-history"
@using QuantInfra.Common.Interfaces.Api.Accounts

@layout Reporting

<UI.SharedComponents.Components.Accounts.BalanceOperationsHistory SingleAccount="true" Filter=@(new BalanceOperationsFilter { AccountId = AccountId }) />

@code {
    [Parameter] public int AccountId { get; set; }
    
    [CascadingParameter] public AccountBase AccountBase { get; set; }
    [CascadingParameter] public Reporting Reporting { get; set; }

    protected override void OnInitialized()
    {
        AccountBase.Id = AccountId;
        Reporting.Path = "balance-operations-history";
    }
}