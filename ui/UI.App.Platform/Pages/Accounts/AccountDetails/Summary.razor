@using QuantInfra.Sdk.Accounts
@using Radzen.Blazor
@using UI.SharedComponents.Components.Accounts

@page "/accounts/{AccountId:int}"
@page "/accounts/{AccountId:int}/summary"

@layout AccountBase

@if (AccountBase?.Account != null)
{
    <RadzenStack Gap="1rem">
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeXS="6" SizeSM="4" SizeMD="3" Size="2" Style="min-width: 350px;">
                <RadzenCard class="details-form-card">
                    <AccountListItemView Account=@AccountBase?.Account
                                         LoadInvestment=@(AccountBase?.Account.EnableSharePriceTracking == true || AccountBase?.Account.AccountType == AccountType.VirtualAccount ||
                                                        AccountBase?.Account.AccountType == AccountType.StrategySubAccount || AccountBase?.Account.AccountType == AccountType.ExecutableSubAccount)/>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenStack>
}

@code {
    [Parameter] public int AccountId { get; set; }

    [CascadingParameter] public AccountBase? AccountBase { get; set; }

    protected override void OnInitialized()
    {
        AccountBase!.Id = AccountId;
        AccountBase!.Path = "summary";
    }
}