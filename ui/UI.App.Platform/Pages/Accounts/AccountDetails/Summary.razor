@using QuantInfra.Sdk.Accounts
@using Radzen
@using Radzen.Blazor
@using UI.SharedComponents.Accounts
@using UI.SharedComponents.Accounts.TradingClients

@page "/accounts/{AccountId:int}"
@page "/accounts/{AccountId:int}/summary"

@layout AccountBase

@if (AccountBase?.Account != null)
{
    <RadzenStack Gap="1rem">
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeXS="6" SizeSM="4" SizeMD="3" Size="2" Style="min-width: 350px;">
                <RadzenCard class="details-form-card">
                    <AccountListItemView Account=@AccountBase?.Account
                                         LoadInvestment=@(AccountBase?.Account.EnableSharePriceTracking == true || AccountBase?.Account.AccountType == AccountType.VirtualAccount ||
                                                        AccountBase?.Account.AccountType == AccountType.StrategySubAccount || AccountBase?.Account.AccountType == AccountType.ExecutableSubAccount)/>
                </RadzenCard>
            </RadzenColumn>
            @if (AccountBase.Account.AccountType == AccountType.BrokerAccount)
            {
                <RadzenColumn SizeXS="6" SizeSM="4" SizeMD="3" Size="2" Style="min-width: 350px;">
                    <RadzenCard class="details-form-card">
                        <RadzenStack AlignItems="AlignItems.Stretch">
                            <RadzenRow>
                                <RadzenColumn Size="12">
                                    <RadzenText TextStyle="TextStyle.DisplayH6">Trading client configuration</RadzenText>
                                </RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="12">
                                    @if (AccountBase.Account.TradingClientConfig == null)
                                    {
                                        <RadzenText TextStyle="TextStyle.Body2">Trading client not configured for this broker account.</RadzenText>
                                    }
                                    else
                                    {
                                        <TradingClientConfigView Config=@new(AccountBase.Account.TradingClientConfig)/>
                                    }
                                </RadzenColumn>
                            </RadzenRow>
                            <RadzenRow JustifyContent="JustifyContent.End">
                                <TradingAccountConfigButtons Account=@AccountBase.Account OnCompleted=@AccountBase.Reload />
                            </RadzenRow>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            }
        </RadzenRow>
    </RadzenStack>
}

@code {
    [Parameter] public int AccountId { get; set; }

    [CascadingParameter] public AccountBase? AccountBase { get; set; }

    protected override void OnInitialized()
    {
        AccountBase!.Id = AccountId;
        AccountBase!.Path = "summary";
    }
}