@page "/accounts/{AccountId:int}/reporting/positions-history"
@using QuantInfra.Common.Interfaces.Api.Accounts
@using UI.Interfaces.Accounts

@layout Reporting

@inject IUiAccountsRepository Repository

@if (AccountBase.Account != null)
{
    <UI.SharedComponents.Accounts.Reporting.PositionsHistory Repository="@Repository" HideAccount="true" Filter=@(new PositionHistoryFilter() { AccountId = AccountBase.Account.AccountId })/>
}

@code {
    [Parameter] public int AccountId { get; set; }
    
    [CascadingParameter] public AccountBase AccountBase { get; set; }
    [CascadingParameter] public Reporting Reporting { get; set; }

    protected override void OnInitialized()
    {
        AccountBase.Id = AccountId;
        Reporting.Path = "positions-history";
    }
}