@page "/accounts/{AccountId:int}/reporting/orders-history"
@using QuantInfra.Common.Interfaces.Api.Accounts

@layout Reporting

@if (AccountBase.Account != null)
{
    <UI.SharedComponents.Accounts.Reporting.OrdersHistory HideAccount="true" 
                                                           Filter="@(new OrderFilter() { AccountId = AccountBase.Account.AccountId })" />
}

@code {
    [Parameter] public int AccountId { get; set; }
    
    [CascadingParameter] public AccountBase AccountBase { get; set; }
    [CascadingParameter] public Reporting Reporting { get; set; }

    protected override void OnInitialized()
    {
        AccountBase.Id = AccountId;
        Reporting.Path = "orders-history";
    }
}