@using UI.SharedComponents.Components.Accounts

@page "/accounts/{AccountId:int}/reconciliation/broker-ssa"

@layout Reconciliation

<BrokerAccountInternalReconciliationReportView AccountId=@AccountId />

@code {
    private bool _brokerPositionsExpanded = true, _brokerOrdersExpanded = true;
    
    [Parameter] public int AccountId { get; set; }
    [CascadingParameter] public AccountBase AccountBase { get; set; }
    [CascadingParameter] public Reconciliation Reconciliation { get; set; }

    protected override void OnInitialized()
    {
        AccountBase.Id = AccountId;
        Reconciliation.Path = "broker-ssa";
    }
}