@using QuantInfra.Sdk.StaticData
@using UI.Interfaces.StaticData

@inject IUiStaticDataRepository Repository

@typeparam TValue

<SearchSelector TItem="Exchange"
                TValue="int"
                ValueProperty="@nameof(Exchange.ExchangeId)"
                ValueSelector="@(a => a.ExchangeId)"
                SearchFunc="@DoSearch"
                Value="@NullableUtils.AsInt(Value)"
                ValueChanged="@(v => NullableUtils.OnInnerValueChanged(v, Required, ValueChanged))"
                IsRequired="@Required"
                @bind-Loading="@_isLoading"
                PreloadData="true">
    <ValueTemplate Context="exchange">
        (@exchange.ExchangeId) @exchange.Name
    </ValueTemplate>
</SearchSelector>

@code {
    private bool _isLoading;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Task<IEnumerable<Exchange>> DoSearch(string? filter)
    {
        return Repository.GetExchanges(new() { Limit = int.MaxValue });
    }
}