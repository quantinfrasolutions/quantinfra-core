@using QuantInfra.Common.StaticData.Abstractions
@using QuantInfra.Sdk.StaticData
@using Radzen.Blazor

<RadzenFormField Text="Id" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenNumeric TValue="int?" @bind-Value=@Filter.Id @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>
<RadzenFormField Text="Name" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.Name @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>
<RadzenFormField Text="Asset type" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenDropDown Name="Type"
                    @bind-Value=@Filter.AssetType
                    @bind-Value:after=@OnPropUpdated
                    AllowClear="true"
                    Multiple="false"
                    Data="@(Enum.GetValues(typeof(AssetType)).Cast<Enum>())"
                    Disabled="@Disabled" />
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public AssetFilter? Filter { get; set; }
    [Parameter] public EventCallback<AssetFilter>? FilterChanged { get; set; }
    // [Parameter] [EditorRequired] public long? Id { get; set; }
    // [Parameter] [EditorRequired] public EventCallback<long?> IdChanged { get; set; }
    //
    // [Parameter] [EditorRequired] public string? Name { get; set; }
    // [Parameter] [EditorRequired] public EventCallback<string?> NameChanged { get; set; }
    //
    // [Parameter] [EditorRequired] public AssetType? AssetType { get; set; }
    // [Parameter] [EditorRequired] public EventCallback<AssetType?> AssetTypeChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Filter == null)
        {
            Filter = new AssetFilter();
            await OnPropUpdated();
        }
    }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}