@using QuantInfra.Common.Interfaces.Api.StaticData
@using UI.Interfaces.StaticData
@using UI.SharedComponents.Base

@inject IUiStaticDataRepository Repository

@typeparam TValue

<SearchSelector TItem="ContractTemplateListView"
                TValue="int"
                ValueProperty="@nameof(ContractTemplateListView.TemplateId)"
                ValueSelector="@(a => a.TemplateId)"
                SearchFunc="@DoSearch"
                Value="@NullableUtils.AsInt(Value)"
                ValueChanged="@(v => NullableUtils.OnInnerValueChanged(v, Required, ValueChanged))"
                IsRequired="@Required"
                @bind-Loading="@_isLoading">
    <ValueTemplate Context="template">
        (@template.AssetId) @template.Name
    </ValueTemplate>
</SearchSelector>

@code {
    private bool _isLoading;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private async Task<IEnumerable<ContractTemplateListView>> DoSearch(string? filter)
    {
        List<Task<IEnumerable<ContractTemplateListView>>> tasks = [Repository.GetContractTemplates(new() { Name = filter })];
        if (int.TryParse(filter, out var templateId))
        {
            tasks.Add(Repository.GetContractTemplates(new() { TemplateId = templateId }));
        }

        return (await Task.WhenAll(tasks)).SelectMany(t => t);
    }
}