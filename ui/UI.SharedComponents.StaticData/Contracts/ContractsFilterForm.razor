@using QuantInfra.Common.Interfaces.Api.StaticData
@using UI.SharedComponents.StaticData.Exchanges

<RadzenFormField Text="IDs (comma-separated)" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox Value=@(string.Join(',', Filter.ContractIds ?? new()))
                   ValueChanged=@OnContractIdsChanged />
</RadzenFormField>
<RadzenFormField Text="Ticker" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.Ticker @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>
<RadzenFormField Text="Exchange" Variant="Variant.Text" Style="min-width: 180px;">
    <ExchangesSelector TValue="int?" @bind-Value="@Filter.ExchangeId" @bind-Value:after="@OnPropUpdated" Required="false" />
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public ContractsFilter Filter { get; set; }
    [Parameter] public EventCallback<ContractsFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    
    
    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;

    private Task OnContractIdsChanged(string arg)
    {
        Filter.ContractIds = arg.Split(',')
            .Select(s => int.TryParse(s.Trim(), out var i) ? i : 0)
            .Where(s => s != 0)
            .ToList();
        
        return OnPropUpdated();
    }

}
