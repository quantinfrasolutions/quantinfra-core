@typeparam TValue
@typeparam TItem where TItem : class

<RadzenDropDown TValue="TValue" 
                Data="@_data"
                Value="@Value"
                ValueChanged="@ValueChanged"
                ValueProperty="@ValueProperty"
                Disabled="@Loading"
                AllowClear="@(!IsRequired)"
                AllowFiltering=@(!PreloadData)
                FilterPlaceholder=@FilterPlaceholder
                LoadData="Callback"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
    <Template>
        @ValueTemplate((TItem)context)
    </Template>
    <ValueTemplate>
        @ValueTemplate((TItem)context)
    </ValueTemplate>
</RadzenDropDown>


@code {
    private List<TItem> _data = new();

    [Parameter]
    public TValue Value { get; set; }

    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<bool> LoadingChanged { get; set; }
    
    [Parameter, EditorRequired] public string ValueProperty { get; set; }
    [Parameter, EditorRequired] public Func<TItem, TValue> ValueSelector { get; set; }
    [Parameter, EditorRequired] public RenderFragment<TItem> ValueTemplate { get; set; }
    [Parameter, EditorRequired] public Func<string?, Task<IEnumerable<TItem>>> SearchFunc { get; set; }
    [Parameter] public string FilterPlaceholder { get; set; } = "Start typing";
    [Parameter] public bool PreloadData { get; set; }
    [Parameter] public bool IsRequired { get; set; }

    SemaphoreSlim _semaphore = new(1);

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (PreloadData)
        {
            await _semaphore.WaitAsync();
            try
            {
                await LoadData(null);
            }
            finally
            {
                _semaphore.Release();
            }
        }

        await _semaphore.WaitAsync();
        var comparer = EqualityComparer<TValue>.Default;
        if (Value is not null && !comparer.Equals(Value, default(TValue)) && !_data.Any(x => comparer.Equals(ValueSelector(x), Value)))
        {
            try
            {
                await LoadData(Value.ToString());
            }
            finally
            {
                _semaphore.Release();
            }
        }
    }

    private async Task LoadData(string? filter)
    {
        Loading = true;
        await LoadingChanged.InvokeAsync(Loading);
        try
        {
            _data = (await SearchFunc(filter)).ToList();
        }
        catch { }
        finally
        {
            Loading = false;
            await LoadingChanged.InvokeAsync(Loading);
        }
    }

    private Task Callback(LoadDataArgs args) => LoadData(args.Filter);

}