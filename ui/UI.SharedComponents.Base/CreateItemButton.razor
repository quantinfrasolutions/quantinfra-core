@inject DialogService DialogService
@typeparam TForm where TForm : ComponentBase

@if (ShowButton)
{
    <RadzenButton Text=@Text ButtonStyle="@ButtonStyle" Icon=@Icon Variant="Variant.Text" Click="Show" />
}

@code {
    [Parameter] public bool ShowButton { get; set; }
    [Parameter] public string? Text { get; set; } = "Create";
    [Parameter] public string? Icon { get; set; } = "add";
    [Parameter] public ButtonStyle ButtonStyle { get; set; } = ButtonStyle.Success;
    [Parameter] public string DialogTitle { get; set; } = "Create";
    [Parameter] public EventCallback OnCompleted { get; set; }
    [Parameter] public Dictionary<string, object> FormParams { get; set; }

    public async Task Show()
    {
        var formParams = FormParams?.ToDictionary(x => x.Key, x => x.Value) ?? new();
        formParams.Add("OnCompleted", new EventCallback(this, WhenDone));
        var dialog = await DialogService.OpenAsync<TForm>(
            DialogTitle,
            formParams,
            new DialogOptions { CloseDialogOnOverlayClick = false, }
        );
    }

    private Task WhenDone()
    {
        DialogService.Close();
        return OnCompleted.InvokeAsync();
    }
}