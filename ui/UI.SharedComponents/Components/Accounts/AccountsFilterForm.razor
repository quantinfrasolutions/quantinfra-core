@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Sdk.Accounts

<RadzenFormField Text="Name" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.AccountName @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>
@if (!HideAccountType)
{
    <RadzenFormField Text="Account type" Variant="Variant.Text" Style="min-width: 180px;">
        <RadzenDropDown Name="Type"
                        @bind-Value=@Filter.AccountTypes
                        @bind-Value:after=@OnPropUpdated
                        AllowClear="true"
                        Multiple="true"
                        Data="@(Enum.GetValues(typeof(AccountType)).Cast<Enum>())"
                        Disabled="@Disabled"/>
    </RadzenFormField>
}

@code {
    [Parameter, EditorRequired] public AccountsFilter? Filter { get; set; }
    [Parameter] public EventCallback<AccountsFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HideAccountType { get; set; }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}