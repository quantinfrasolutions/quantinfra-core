@using QuantInfra.Common.Interfaces.Api
@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Sdk.Trading.Positions
@using UI.SharedComponents.Base
@using UI.SharedComponents.Components.StaticData

@if (!HideAccountSelector)
{
    <AccountsSelector @bind-Value=@Filter.AccountId Required="false" />
}
<ContractsSelector TValue="int?" @bind-Value=@Filter.ContractId />
<RadzenFormField Text="Open from" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24" 
                      Value=@(Filter.OpenDtFrom?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.OpenDtFrom = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="Open to" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24"
                      Value=@(Filter.OpenDtTo?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.OpenDtTo = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="History open from" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24" 
                      Value=@(Filter.HistoryOpenDtFrom?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.HistoryOpenDtFrom = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="History open to" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24"
                      Value=@(Filter.HistoryOpenDtTo?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.HistoryOpenDtTo = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="Close from" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24" 
                      Value=@(Filter.CloseDtFrom?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.CloseDtFrom = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="Close to" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24"
                      Value=@(Filter.CloseDtTo?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.CloseDtTo = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="TradeId" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenNumeric TValue="long?" @bind-Value=@Filter.TradeId Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="Close type" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDropDown Multiple="true" Data=@(Enum.GetValues(typeof(PositionChangeType)).Cast<Enum>()) Chips="true" @bind-Value=@Filter.Type />
</RadzenFormField>
    

@code {
    [Parameter, EditorRequired] public PositionHistoryFilter Filter { get; set; }
    [Parameter] public EventCallback<PositionHistoryFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HideAccountSelector { get; set; }
    
    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}