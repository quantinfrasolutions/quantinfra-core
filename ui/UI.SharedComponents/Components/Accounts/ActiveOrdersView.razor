@using UI.Interfaces.Accounts
@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Sdk.Trading
@using QuantInfra.Sdk.Trading.Orders
@using UI.SharedComponents.Base

@inject IUiAccountsRepository Repository
@inject DialogService DialogService

@if (AccountId != 0)
{
    <EditableView TItem="OrderView"
                  TFilter="int"
                  EmptyText="No orders"
                  SearchFunc=@Repository.GetActiveOrders
                  Filter=@AccountId
                  RunSearchImmediately="true"
                  @ref=_view
                  SearchButtonText="Refresh"
                  IsLoading=@_isLoading
                  CellRender=@CellRender
                  HideRefreshButton=@HideRefreshButton
                  AllowSorting="true"
                  DefaultOrderBy=@nameof(OrderView.ContractName)
                  Variant=@Variant>
        <SearchForm/>
        @* <SearchForm> *@
        @*     @if (ShowFilter) *@
        @*     { *@
        @*         <ActiveOrdersFilterForm @bind-Filter=@Filter HideAccountSelector=@HideAccountFilter Disabled=@_isLoading /> *@
        @*     } *@
        @* </SearchForm> *@
        <CreateButton>
            @if (AllowNewOrder)
            {
                <NewOrderDialog AccountId=@AccountId ShowButton="true" OnCompleted=@OnOrderChanged HideAccountSelector=@HideAccountFilter />
            }
        </CreateButton>
        <CustomItemButtons Context="order">
            <RadzenButton Variant="Variant.Text" Icon="close" ButtonStyle="ButtonStyle.Danger" ImageAlternateText="Cancel order" Click=@(() => CancelOrder(order)) />
        </CustomItemButtons>
        <Columns>
            <RadzenDataGridColumn TItem="OrderView" Property=@nameof(OrderView.OrderId) Title="Id" Width="120px" Frozen="true" />
            <RadzenDataGridColumn TItem="OrderView" Property="ClOrdId" Title="ClOrdId" Width="120px" Frozen="true"  />
            <RadzenDataGridColumn TItem="OrderView" Property="ExternalId" Title="External Id" Width="120px" Frozen="true"  />
            @if (ShowAccountColumn)
            {
                <RadzenDataGridColumn TItem="OrderView" Property=@nameof(OrderView.AccountId) Title="Account Id" Width="120px" />
                <RadzenDataGridColumn TItem="OrderView" Title="Account" Width="120px">
                    <Template Context="order">
                        <RadzenLink Path=@($"accounts/{order.AccountId}") Text=@order.AccountName/>
                    </Template>
                </RadzenDataGridColumn>
            }
            @if (ShowBrokerAccountColumn)
            {
                <RadzenDataGridColumn TItem="OrderView" Property=@nameof(OrderView.BrokerAccountId) Title="Broker account Id" Width="120px" />
                <RadzenDataGridColumn TItem="OrderView" Title="Broker Account" Width="120px">
                    <Template Context="account">
                        <RadzenLink Path=@($"accounts/{account.BrokerAccountId}") Text=@account.BrokerAccountName/>
                    </Template>
                </RadzenDataGridColumn>
            }
            <RadzenDataGridColumn TItem="OrderView" Title="Contract ID" Property="ContractId" Width="120px"/>
            <RadzenDataGridColumn TItem="OrderView" Title="Ticker" Property="ContractName" Width="120px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="OrdType" Title="OrdType" Width="100px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="OrderQty" Title="OrderQty" Width="120px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="Side" Title="Side" Width="80px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="Price" Title="Price" Width="100px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="StopPx" Title="StopPx" Width="100px"/>
            <RadzenDataGridColumn TItem="OrderView" Property=@(nameof(OrderView.IsSuspended)) Title="Suspended" Width="100px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="OrdStatus" Title="OrdStatus" Width="100px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="LeavesQty" Title="LeavesQty" Width="120px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="PositionEffect" Title="PositionEffect" Width="100px"/>
            <RadzenDataGridColumn TItem="OrderView" Property="StrategyPositionId" Title="StrategyPositionId" Width="250px"/>
        </Columns>
    </EditableView>
}

@code {
    private EditableView<OrderView, int> _view;
    private bool _isLoading;
    
    // [Parameter] public ActiveOrderFilter? Filter { get; set; }
    [Parameter] public int AccountId { get; set; }
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool HideAccountFilter { get; set; }
    [Parameter] public bool ShowAccountColumn { get; set; } = true;
    [Parameter] public bool ShowBrokerAccountColumn { get; set; } = true;
    [Parameter] public bool ShowFilter { get; set; } = true;
    [Parameter] public bool AllowNewOrder { get; set; }
    [Parameter] public bool AllowCancelOrder { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool StrategyVariant { get; set; }
    [Parameter] public int? StrategyId { get; set; }
    [Parameter] public bool AutoRefresh { get; set; } = true;
    [Parameter] public EventCallback ReloadRequested { get; set; }
    [Parameter] public bool HideRefreshButton { get; set; }
    
    public Task Refresh() => _view.RunSearch();

    // protected override async Task OnParametersSetAsync()
    // {
    //     await base.OnParametersSetAsync();
    //     // Filter ??= new();
    // }

    private async Task CancelOrder(OrderView order)
    {
        var res = await DialogService.Confirm(
            GetMessage(order), 
            "Cancel order?",
            new ConfirmOptions
            {
                OkButtonText = "Cancel order",
                CancelButtonText = "Keep order",
            }
        );

        if (res == true)
        {
            _isLoading = true;
            try
            {
                await Repository.CancelOrder(new OrderCancelRequest(order.AccountId, $"{Guid.NewGuid()}", order.OrderId, null));
                await OnOrderChanged();
            }
            finally
            {
                _isLoading = false;
            }
        }
    }
    
    private RenderFragment GetMessage(OrderView order)
    {
        return __builder =>
        {
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.Body2">You are about to cancel the order:</RadzenText>
                <RadzenTable>
                    <RadzenTableBody>
                        <RadzenTableRow>
                            <RadzenTableCell>Order Id</RadzenTableCell>
                            <RadzenTableCell>@order.OrderId</RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>ClOrdId</RadzenTableCell>
                            <RadzenTableCell>@order.ClOrdId</RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>Contract</RadzenTableCell>
                            <RadzenTableCell>@IdNameView.GetLabel(order.ContractId, order.ContractName)</RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>Side</RadzenTableCell>
                            <RadzenTableCell>@order.Side</RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>Type</RadzenTableCell>
                            <RadzenTableCell>@order.OrdType</RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>OrderQty</RadzenTableCell>
                            <RadzenTableCell>@order.OrderQty</RadzenTableCell>
                        </RadzenTableRow>
                    </RadzenTableBody>
                </RadzenTable>
            </RadzenStack>
        };
    }

    string GetLookIntoHref(AccountListModel a) => $"/accounts/{a.AccountId}";

    void CellRender(DataGridCellRenderEventArgs<OrderView> args)
    {
        if (args.Column.Property == "Side")
        {
            args.Attributes.Add("class", args.Data.Side == Side.Buy ? "rz-background-color-success" : "rz-background-color-danger");
        }

        if (args.Column.Property == "OrdStatus")
        {
            args.Attributes.Add("class", args.Data.OrdStatus switch
            {
                OrdStatus.PendingNew => "rz-background-color-success-lighter",
                OrdStatus.New => "rz-background-color-success-light",
                OrdStatus.PartiallyFilled => "rz-background-color-success-dark",
                OrdStatus.Suspended => "rz-background-color-primary-lighter",
                OrdStatus.PendingCancel => "rz-background-color-warning-lighter",
                _ => ""
            });
        }
    }

    private async Task OnOrderChanged()
    {
        await ReloadRequested.InvokeAsync();
        if (AutoRefresh) await Refresh();
    }
}

