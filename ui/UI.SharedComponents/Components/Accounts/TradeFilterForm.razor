@using QuantInfra.Common.Interfaces.Api
@using QuantInfra.Common.Interfaces.Api.Accounts

@if (!HideAccountSelector)
{
    if (UseSimpleAccountSelector)
    {
        <RadzenFormField Text="AccountId" Variant="Variant.Text" Style="min-width: 180px;">
            <RadzenNumeric TValue="int?" ShowUpDown="false" @bind-Value=@Filter.AccountId />
        </RadzenFormField>
    }
    else
    {
        <AccountsSelector @bind-Value=@Filter.AccountId Required="false" />
    }
}
<RadzenFormField Text="FromDt" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24"
                      Value=@(Filter.FromDt?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.FromDt = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="ToDt" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24"
                      Value=@(Filter.ToDt?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.ToDt = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="TradeId" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenNumeric TValue="long?" @bind-Value=@Filter.TradeId Disabled="@Disabled" />
</RadzenFormField>
    

@code {
    [Parameter, EditorRequired] public TradeFilter Filter { get; set; }
    [Parameter] public EventCallback<TradeFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HideAccountSelector { get; set; }
    [Parameter] public bool UseSimpleAccountSelector { get; set; }
    
    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}
