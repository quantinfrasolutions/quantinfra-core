@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Common.Interfaces.Api.Strategies
@using UI.Interfaces.Accounts
@using UI.SharedComponents.Base

@inject IUiAccountsRepository Repository

@if (AccountId != 0)
{
    <EditableView TItem="PositionView"
                  TFilter="int"
                  EmptyText="No active positions"
                  SearchFunc=@Repository.GetActivePositions
                  Filter=@AccountId
                  RunSearchImmediately=@RunSearchImmediately
                  SearchButtonText="Refresh"
                  Variant=@Variant
                  ButtonsColumnWidth=@(StrategyVariant ? "52px" : "0")
                  HideRefreshButton=@HideRefreshButton
                  AllowSorting="true"
                  DefaultOrderBy=@(nameof(PositionView.ContractName))
                  @ref=_view>
        @* <SearchForm> *@
        @*     @if (!HideFilter) *@
        @*     { *@
        @*         <ActivePositionsFilterForm @bind-Filter=@_filter HideAccountSelector=@HideAccount /> *@
        @*     } *@
        @* </SearchForm> *@
        <SearchForm />
        <CustomButtons>
            @if (StrategyVariant && Strategy != null)
            {
                <UI.SharedComponents.Components.Strategies.OpenClosePositionDialog Strategy=@Strategy 
                                                                                   IsOpen="true" 
                                                                                   ShowButton="true" 
                                                                                   Text="Open position"
                                                                                   OnCompleted=@ReloadRequested/>
            }
        </CustomButtons>
        <CustomItemButtons Context="position">
            @if (StrategyVariant)
            {
                @* <UI.SharedComponents.Components.Strategies.OpenClosePositionDialog Strategy=@Strategy  *@
                @*                                                               IsOpen="false"  *@
                @*                                                               ShowButton="true"  *@
                @*                                                               Icon="close"  *@
                @*                                                               ButtonStyle="ButtonStyle.Danger"  *@
                @*                                                               Request=@(new() { StrategyPositionId = position.StrategyPositionId, Symbol = Strategy.Symbols.Single(kv => kv.Value.Id == position.ContractId).Key }) *@
                @*                                                               OnCompleted=@ReloadRequested/> *@
            }
        </CustomItemButtons>
        <Columns>
            @if (!HideAccount)
            {
                <RadzenDataGridColumn TItem="PositionView" Title="AccountId" Property=@nameof(PositionView.AccountId) Width="120px" />
                <RadzenDataGridColumn TItem="PositionView" Title="Account Name" Property="AccountName" Width="120px" />
            }
            <RadzenDataGridColumn TItem="PositionView" Title="Contract" Property=@nameof(PositionView.ContractId) Width="120px" />
            <RadzenDataGridColumn TItem="PositionView" Title="Ticker" Property=@nameof(PositionView.ContractName) Width="120px" />
            <RadzenDataGridColumn TItem="PositionView" Property="Volume" Title="Volume" Width="120px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="Side" Title="Side" Width="80px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="OpenDt" Title="OpenDt" Width="200px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="OpenPrice" Title="OpenPrice" Width="100px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="HistoryOpenDt" Title="HistoryOpenDt" Width="200px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="SettlPrice" Title="SettlPrice" Width="100px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="Commission" Title="Commission" Width="100px"/>
            <RadzenDataGridColumn TItem="PositionView" Property=@nameof(PositionView.OpenTradeId) Title="PositionId" Width="120px"/>
            <RadzenDataGridColumn TItem="PositionView" Property="StrategyPositionId" Title="StrategyPositionId" Width="120px"/>
        </Columns>
    </EditableView>
}

@code {
    [Parameter] public int AccountId { get; set; }
    [Parameter] public bool HideAccount { get; set; }
    [Parameter] public bool HideFilter { get; set; }
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool StrategyVariant { get; set; }
    [Parameter] public StrategyViewBrief? Strategy { get; set; }
    [Parameter] public bool AutoRefresh { get; set; } = true;
    [Parameter] public EventCallback ReloadRequested { get; set; }
    [Parameter] public bool HideRefreshButton { get; set; }
    
    private EditableView<PositionView, int> _view;
    public Task Refresh() => _view.RunSearch();
    
    private async Task OnPositionChanged()
    {
        await ReloadRequested.InvokeAsync();
        if (AutoRefresh) await Refresh();
    }
}