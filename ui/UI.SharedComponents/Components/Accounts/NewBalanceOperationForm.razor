@using QuantInfra.Sdk.Accounting

<RadzenStack Orientation="Orientation.Vertical">
    <RadzenTabs SelectedIndexChanged=@SelectedTabChanged>
        <Tabs>
            <RadzenTabsItem Text="Balance operation" />
            <RadzenTabsItem Text="Correction" />
        </Tabs>
    </RadzenTabs>
    <NewBalanceOperationFormRaw Value=@Value
                                Disabled=@Disabled
                                CorrectionDisabled="@(!_isCorrection)"
                                HideAccountSelector=@HideAccountSelector
                                OnCompleted=@OnCompleted />
</RadzenStack>

@code {
    [Parameter] public NewBalanceOperation? Value { get; set; }
    [Parameter] public int AccountCurrencyId { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HideAccountSelector { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }
    
    bool _isCorrection = false;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        Value ??= new();
        if (AccountCurrencyId != 0) Value.AssetId = AccountCurrencyId;
        SelectedTabChanged(0);
    }

    void SelectedTabChanged(int index)
    {
        switch (index)
        {
            case 0:
                _isCorrection = false;
                Value!.IsCorrection = false;
                Value.AffectsPnL = false;
                Value.AffectsInvestment = true;
                Value.AffectsBalance = true;
                break;
            case 1:
                _isCorrection = true;
                break;
        }
    }
}