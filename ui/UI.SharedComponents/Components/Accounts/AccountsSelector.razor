@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Sdk.Accounts
@using UI.SharedComponents.Base

@typeparam TValue

<SearchSelector TKey="int?"
                TItem="AccountListModel"
                Text="Account"
                Required=@Required
                @ref=_selector
                KeySelector="@(c => c.AccountId)"
                LabelSelector="@(c => c.Name)"
                Value=@(Value as int?)
                ValueChanged=@OnValueChanged
                SomethingSelected="@(Value is Guid? && Value as Guid? != Guid.Empty)"
                Disabled=@Disabled
                >
    <Selector>
        <AccountsView AllowSelect="true" 
                      ValueChanged=@_selector.OnSomethingSelected 
                      Variant="Variant.Flat" 
                      RunSearchImmediately=@(AccountType != null || AccountTypes?.Count > 0)
                      StrategyId=@StrategyId
                      AccountType=@AccountType 
                      AccountTypes=@AccountTypes 
                      EnableActions="false"/>
    </Selector>
</SearchSelector>

@code {
    private SearchSelector<int?, AccountListModel> _selector;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public int? StrategyId { get; set; }
    [Parameter] public AccountType? AccountType { get; set; }
    [Parameter] public List<AccountType>? AccountTypes { get; set; }
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private async Task OnValueChanged(int? value)
    {
        if (!Required || (Required && value != null))
        {
            Value = (TValue)(object)value;
            await ValueChanged.InvokeAsync(Value);
        }
    }
}