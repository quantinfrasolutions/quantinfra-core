@using UI.SharedComponents.Components.StaticData
@using QuantInfra.Common.Interfaces.Api.Accounts
@using UI.SharedComponents.Components.StaticData.Contracts

@if (!HideAccountSelector)
{
    @* <AccountsSelector/> *@
}
<ContractsSelector @bind-Value=@Filter.ContractId Required="false" />
<RadzenFormField Text="Ticker" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox Value=@Filter.TradeId.ToString() ValueChanged=@TrySetPositionId Disabled=@Disabled />
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public ActivePositionFilter Filter { get; set; }
    [Parameter] public EventCallback<ActivePositionFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HideAccountSelector { get; set; }
    
    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;

    private async Task TrySetPositionId(string arg)
    {
        try
        {
            Filter.TradeId = int.Parse(arg);
            await OnPropUpdated();
        }
        catch
        {
            Filter.TradeId = null;
        }
    }

}