@using QuantInfra.Common.Accounts.Abstractions
@using QuantInfra.Sdk.Accounts
@using UI.Interfaces.Accounts
@using UI.SharedComponents.Components.StaticData.Brokers
@using UI.SharedComponents.Infrastructure

@inject IUiAccountsRepository Repository

<RadzenTemplateForm TItem="CreateAccountRequest"
                    Data="@_account"
                    @ref="form"
                    Submit=@CreateStrategy>
    <RadzenStack Gap="1rem" AlignItems="AlignItems.Stretch">
        <RadzenRow>
            <AccountsServiceSelector TValue="string" @bind-Value=@_account.AccountServiceName />
        </RadzenRow>
        <RadzenRow>
            <RadzenFormField Text="Name" Variant="Variant.Text">
                <RadzenTextBox @bind-Value="_account.Name"/>
            </RadzenFormField>
        </RadzenRow>
        <RadzenRow>
            <RadzenFormField Text="Account type" Variant="Variant.Text">
                <RadzenDropDown @bind-Value="@_account.AccountType"
                                Data=@_supportedAccountTypes
                                Disabled=@_isLoading/>
            </RadzenFormField>
        </RadzenRow>
        @if (_account.AccountType == AccountType.BrokerAccount)
        {
            <RadzenRow>
                <BrokersSelector @bind-Value=@_account.BrokerId/>
            </RadzenRow>
        }
        <RadzenRow>
            @* <CurrenciesSelector @bind-Value=@_account.CurrencyId/> *@
        </RadzenRow>
        <RadzenRow>
            <RadzenFormField Text="Position tracking" Variant="Variant.Text">
                <RadzenDropDown @bind-Value="@_account.PositionAccounting"
                                Data=@(Enum.GetValues(typeof(PositionAccounting)).Cast<Enum>())
                                Disabled=@_isLoading/>
            </RadzenFormField>
        </RadzenRow>
        <RadzenRow>
            <RadzenCheckBox TValue="bool" @bind-Value=@_account.EnableSharePriceTracking Disabled=@_isLoading Name="EnableMt"/>
            <RadzenLabel Text="Enable share price tracking" Component="EnableMt" class="rz-ms-2"/>
        </RadzenRow>
        @if (_account.EnableSharePriceTracking)
        {
            <RadzenRow>
                <RadzenCheckBox TValue="bool" @bind-Value=@_account.IncludeUnrealizedPnLToMtm Disabled=@_isLoading Name="IncludeUnrealizedPnLToMtm"/>
                <RadzenLabel Text="Include unrealized PnL to returns" Component="IncludeUnrealizedPnLToMtm" class="rz-ms-2"/>
            </RadzenRow>
        }
        <RadzenRow JustifyContent="JustifyContent.End">
            <RadzenButton ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" Text="Create account" Variant="Variant.Text"/>
        </RadzenRow>
    </RadzenStack>
</RadzenTemplateForm>


@code {
    private bool _isLoading;
    private readonly List<AccountType> _supportedAccountTypes = [AccountType.StrategySubAccount, AccountType.ExecutableSubAccount, AccountType.Fund, AccountType.BrokerAccount];
    private CreateAccountRequest _account = new();
    
    [Parameter] public AccountType? Type { get; set; }
    [Parameter] public bool HideAccountType { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Type != null && _supportedAccountTypes.Contains(Type.Value))
        {
            _account.AccountType = Type.Value;
        }
    }

    RadzenTemplateForm<CreateAccountRequest> form;

    public async Task CreateStrategy()
    {
        try
        {
            _isLoading = true;
            await Repository.CreateAccount(_account);
            await OnCompleted.InvokeAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }
}

