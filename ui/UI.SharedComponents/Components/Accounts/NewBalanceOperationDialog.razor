@using QuantInfra.Sdk.Accounting
@inject DialogService DialogService

@if (ShowButton)
{
    <RadzenButton Text="New balance operation" ButtonStyle="ButtonStyle.Success" Icon="add" Variant="Variant.Text" Click=@Show />
}

@code {
    [Parameter] public bool ShowButton { get; set; }
    [Parameter] public int? AccountId { get; set; }
    [Parameter] public int AccountCurrencyId { get; set; }
    [Parameter] public bool HideAccountSelector { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }

    dynamic? _dialog;

    public void Show()
    {
        var bo = new NewBalanceOperation();
        if (AccountId.HasValue) bo.AccountId = AccountId.Value;
        if (AccountCurrencyId != 0) bo.AssetId = AccountCurrencyId;
        
        DialogService.Open<NewBalanceOperationForm>(
            "New balance operation",
            new Dictionary<string, object>()
            {
                { "Value", bo },
                { "HideAccountSelector", HideAccountSelector },
                { "OnCompleted", new EventCallback(this, Close) }
            },
            new()
            {
                CloseDialogOnOverlayClick = false
            }
        );
    }
    

    async Task Close()
    {
        DialogService.Close(_dialog);
        await OnCompleted.InvokeAsync();
    }
}

