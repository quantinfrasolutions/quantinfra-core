@using NodaTime.Text
@using QuantInfra.Common.Interfaces.Api.MarketData
@using QuantInfra.Sdk.MarketData

<RadzenStack Gap="1rem">
    @if (Editable && AllowAddDeleteItems)
    {
        <RadzenRow>
            <RadzenButton ButtonStyle="ButtonStyle.Success" Variant="Variant.Text" Icon="add" Click=@InsertRow Disabled="@(_newBs != null)" />
        </RadzenRow>
    }
    <RadzenDataGrid TItem="BarStorage"
                    Data=@_data
                    Density="Density.Compact"
                    EditMode="DataGridEditMode.Single"
                    @ref="bsGrid">

        <Columns>
            <RadzenDataGridColumn TItem="BarStorage" Title="Name" Property="Key">
                <EditTemplate Context="bs">
                    <RadzenFormField Variant="Variant.Text" Text="Name">
                        <RadzenTextBox @bind-Value=@bs.Key Disabled="@(bs != _newBs)" />
                    </RadzenFormField>
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="BarStorage" Title="Type" Property="BsView.IdType">
                <EditTemplate Context="bs">
                    <RadzenFormField Variant="Variant.Text">
                        <RadzenDropDown Name="IdType"
                                        AllowClear="false"
                                        @bind-Value="@bs.BsView.IdType"
                                        Data="@(Enum.GetValues(typeof(IdType)).Cast<Enum>())"
                                        Disabled="@Disabled"/>
                    </RadzenFormField>
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="BarStorage" Title="Id">
                <Template Context="bs">
                    <IdNameView Id=@bs.BsView.Id Name=@bs.BsView.Ticker />
                </Template>
                <EditTemplate Context="bs">
                    @if (bs.BsView.IdType == IdType.Stream)
                    {
                        <UI.SharedComponents.Components.StaticData.StreamsSelector @bind-Value=@bs.BsView.Id @bind-Label=@bs.BsView.Ticker />
                    }
                    else if (bs.BsView.IdType == IdType.Contract)
                    {
                        <UI.SharedComponents.Components.StaticData.ContractsSelector @bind-Value=@bs.BsView.Id @bind-Label=@bs.BsView.Ticker/>
                    }
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="BarStorage" Title="Aggregation Type" Property="BsView.AggregationType">
                <EditTemplate Context="bs">
                    <RadzenDropDown Name="AggType"
                                    AllowClear="false"
                                    @bind-Value=@bs.BsView.AggregationType
                                    Data="@(Enum.GetValues(typeof(BarAggregationType)).Cast<Enum>())"/>
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="BarStorage" Title="Timeframe" Property="Value.Timeframe">
                <EditTemplate Context="bs">
                    <RadzenFormField Text="Timeframe" Variant="Variant.Text">
                        @* <UI.SharedComponents.Components.PeriodBuilder @bind-Value="bs.BsView.Timeframe"/> *@
                    </RadzenFormField>
                </EditTemplate>
                <Template Context="bs">
                    @PeriodPattern.Roundtrip.Format(bs.BsView.Timeframe)
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="BarStorage" Title="Offset" Property="Value.Offset">
                <EditTemplate Context="bs">
                    <RadzenFormField Text="Timeframe" Variant="Variant.Text">
                        @* <UI.SharedComponents.Components.PeriodBuilder @bind-Value="bs.BsView.Offset"/> *@
                    </RadzenFormField>
                </EditTemplate>
                <Template Context="bs">
                    @PeriodPattern.Roundtrip.Format(bs.BsView.Offset)
                </Template>
            </RadzenDataGridColumn>
            @if (Editable)
            {
                <RadzenDataGridColumn TItem="BarStorage">
                    <Template Context="bs">
                        <RadzenButton ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Icon="edit" Click=@(_ => EditRow(bs)) Disabled="@_isEditing"/>
                        @if (AllowAddDeleteItems)
                        {
                            <RadzenButton ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Text" Icon="delete" Click=@(_ => DeleteRow(bs)) Disabled="@_isEditing"/>
                        }
                    </Template>
                    <EditTemplate Context="bs">
                        <RadzenButton ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Icon="check" Click=@(_ => ConfirmEdit(bs)) Disabled="@(bs == _newBs && (string.IsNullOrEmpty(bs.Key) || BarStorages.ContainsKey(bs.Key) || bs.BsView.Id == 0))" />
                        <RadzenButton ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Text" Icon="close" Click=@(_ => CancelEdit())/>
                    </EditTemplate>
                </RadzenDataGridColumn>
            }
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {

    private Dictionary<string, BarStorageView> _barStorages;
    [Parameter, EditorRequired]
    public Dictionary<string, BarStorageView> BarStorages
    {
        get => _barStorages;
        set
        {
            _barStorages = value;
            ResetData();
        }
    }

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Editable { get; set; }
    [Parameter] public bool AllowAddDeleteItems { get; set; }

    RadzenDataGrid<BarStorage> bsGrid;
    private bool _isInEditMode;
    List<BarStorage> _data = new();

    BarStorage? _newBs = null;
    bool _isEditing;
   

    async Task InsertRow()
    {
        if (!bsGrid.IsValid) return;

        _newBs = new BarStorage { Key = "main", BsView = new() };
        await bsGrid.InsertRow(_newBs);
        _isEditing = true;
    }
    
    private Task EditRow(BarStorage bs)
    {
        return bsGrid.EditRow(bs);
    }

    private void ConfirmEdit(BarStorage bs)
    {
        if (bs == _newBs)
        {
            _newBs = null;
            BarStorages.Add(bs.Key, bs.BsView);
            bsGrid.CancelEditRow(bs);
            ResetData();
        }
        else
        {
            BarStorages[bs.Key] = bs.BsView;
            bsGrid.CancelEditRow(bs);
            ResetData();
        }

        _isEditing = false;
    }
    
    private void CancelEdit()
    {
        _isEditing = false;
        _newBs = null;
        ResetData();
    }

    private void DeleteRow(BarStorage bs)
    {
        if (bs == _newBs)
        {
            _newBs = null;
            bsGrid.CancelEditRow(bs);
        }
        else
        {
            BarStorages.Remove(bs.Key);
            ResetData();
        }
    }

    private void ResetData()
    {
        _data = BarStorages.Select(kv => new BarStorage { Key = kv.Key, BsView = kv.Value.Copy() }).ToList();
    }

    class BarStorage
    {
        public string Key { get; set; }
        public BarStorageView BsView { get; set; }
    }
}