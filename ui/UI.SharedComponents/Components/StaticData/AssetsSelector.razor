@using QuantInfra.Sdk.Accounts
@using QuantInfra.Sdk.StaticData
@using UI.SharedComponents.Base

@typeparam TValue

<SearchSelector TKey="int?"
                TItem="Asset"
                Text="Asset"
                Required=@Required
                @ref=_selector
                KeySelector="@(c => c.AssetId)"
                LabelSelector="@(c => c.Name)"
                Value=@(Value as int?)
                ValueChanged=@OnValueChanged
                SomethingSelected="@(Value is long? && Value as long? != 0)"
                Disabled=@Disabled
                >
    <Selector>
        <AssetsView AllowSelect="true" ValueChanged=@_selector.OnSomethingSelected Variant="Variant.Flat" RunSearchImmediately=@AccountType.HasValue EnableActions="false"/>
    </Selector>
</SearchSelector>

@code {
    private SearchSelector<int?, Asset> _selector;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public AccountType? AccountType { get; set; }
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private async Task OnValueChanged(int? value)
    {
        if (!Required || (Required && value != null))
        {
            Value = (TValue)(object)value;
            await ValueChanged.InvokeAsync(Value);
        }
    }
}