@using QuantInfra.Common.Interfaces.Api.StaticData
@using UI.SharedComponents.Base

@typeparam TValue

<SearchSelector TKey="int?" 
                TItem="ContractListView" 
                Text="Contract"
                Required=@Required
                @ref=_selector
                KeySelector="@(c => c.ContractId)"
                LabelSelector="@(c => c.Ticker)"
                Value=@(Value as int?)
                ValueChanged=@OnValueChanged
                SomethingSelected="@(Value is long? && Value as long? != 0)"
                Disabled=@Disabled
                ItemChanged=@ItemChanged
                >
    <Selector>
        <ContractsView BriefView="true" AllowSelect="true" ValueChanged=@_selector.OnSomethingSelected Variant="Variant.Flat" EnableActions="false" />
    </Selector>
</SearchSelector>

@code {
    private SearchSelector<int?, ContractListView> _selector;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    
    [Parameter] public string Label { get; set; }
    [Parameter] public EventCallback<string> LabelChanged { get; set; }
    
    [Parameter] public EventCallback<ContractListView?> ItemChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    [Parameter] public bool Disabled { get; set; }
    
    private async Task OnValueChanged(int? value)
    {
        if (!Required || (Required && value != null))
        {
            Value = (TValue)(object)value;
            await ValueChanged.InvokeAsync(Value);
        }
    }
}