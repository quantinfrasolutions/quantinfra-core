@using QuantInfra.Common.Interfaces.Api.StaticData
@using QuantInfra.Sdk.StaticData
@using UI.Interfaces.StaticData
@using UI.SharedComponents.Base

@inject IUiCommissionsRepository Repository

<EditableView TItem="CommissionStructure"
             TFilter="CommissionsFilter"
             EmptyText="No commissions found"
             SearchFunc="@Repository.GetCommissions"
             Filter="@Filter"
             RunSearchImmediately="false"
             Variant=@Variant
             HideActionsColumn=@(!EnableActions)
             AllowSelectRow=@AllowSelect
             SelectionMode="DataGridSelectionMode.Single"
             SelectAction=@ValueChanged>
    <SearchForm />
    <Columns>
        <RadzenDataGridColumn TItem="CommissionStructure" Property=@nameof(CommissionStructure.CommissionId) Width="100px" Title="Id" />
        <RadzenDataGridColumn TItem="CommissionStructure" Property=@nameof(CommissionStructure.Name) Width="200px" Title="Name" />
        <RadzenDataGridColumn TItem="CommissionStructure" Property=@nameof(CommissionStructure.FixedPerShare) Width="150px" Title="Fixed per share" />
        <RadzenDataGridColumn TItem="CommissionStructure" Property=@nameof(CommissionStructure.Floating) Width="150px" Title="Floating" />
        <RadzenDataGridColumn TItem="CommissionStructure" Property="Currency.CurrencyId" Width="100px" Title="CurrencyId" />
        <RadzenDataGridColumn TItem="CommissionStructure" Property="Currency.Asset.Name" Width="120px" Title="Currency" />
        <RadzenDataGridColumn TItem="CommissionStructure" Property=@nameof(CommissionStructure.CommissionStructureType) Width="150px" Title="Type" />
        @* TODO: Broker and Exchange names *@
        <RadzenDataGridColumn TItem="CommissionStructure" Property=@nameof(CommissionStructure.Description) Width="200px" Title="Id" />
    </Columns>
</EditableView>

@code {
    [Parameter] public CommissionsFilter Filter { get; set; } = new();
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool AllowEdit { get; set; }
    [Parameter] public bool AllowSelect { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool EnableActions { get; set; } = true;
    [Parameter] public EventCallback<CommissionStructure> ValueChanged { get; set; }
}