@using QuantInfra.Common.Interfaces.Api.StaticData
@using UI.Interfaces.StaticData
@using UI.SharedComponents.Base

@inject IUiContractsRepository Repository

<EditableView TItem="ContractListView"
              TFilter="ContractsFilter"
              EmptyText="No contracts found"
              SearchFunc=@Repository.GetContracts
              Filter=@Filter
              LookIntoHref="GetLookIntoHref"
              AllowSelectRow=@AllowSelect
              SelectionMode="DataGridSelectionMode.Single"
              SelectAction=@OnRowSelected
              Variant=@Variant
              HideActionsColumn=@(!EnableActions)>
    <SearchForm>
        <ContractsFilterForm @bind-Filter=@Filter />
    </SearchForm>
    <Columns>
        <RadzenDataGridColumn Frozen="true" TItem="ContractListView" Property=@nameof(ContractListView.ContractId) Title="ID" Width="100px"/>
        <RadzenDataGridColumn Frozen="true" TItem="ContractListView" Property=@nameof(ContractListView.Ticker) Title="Ticker" Width="180px"/>
        <RadzenDataGridColumn TItem="ContractListView" Property="Template.SecurityType" Title="Type" Width="100px"/>
        <RadzenDataGridColumn TItem="ContractListView" Property="ExternalContractId" Title="External Id" Width="180px"/>
        @if (!BriefView)
        {
            @* <RadzenDataGridColumn TItem="Contract" Property="SettlementCurrency?.Name" Title="SettlCcy" Width="100px" /> *@
            
            <RadzenDataGridColumn TItem="ContractListView" Property="FirstTradingDate" Title="First Dt" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="ExpirationDate" Title="Exp Dt" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="SyntheticContractType" Title="Synth type" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Title="Bars recalc" Width="100px">
                <Template Context="contract">
                    <RadzenCheckBox Value="@contract.SynthRequiresBarRecalculationAtRollover" Disabled="true" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.TemplateId" Title="Template" Width="80px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.Name" Title="" Width="120px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.MinSize" Title="MinSize" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.SizeIncrement" Title="SizeInc" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.TickSize" Title="TickSize" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.TickValue" Title="TickValue" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.PlCalculatorType" Title="PLCalc" Width="100px"/>
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.ExchangeId" Title="Exchange" Width="60px" />
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.ExchangeName" Title="" Width="100px" />
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.BrokerId" Title="Broker" Width="60px" />
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.BrokerName" Title="" Width="100px" />
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.AssetId" Title="Asset" Width="100px" />
            <RadzenDataGridColumn TItem="ContractListView" Property="Template.AssetName" Title="" Width="160px" />
            
            @* <RadzenDataGridColumn TItem="ContractListView" Title="Datafeed" Width="100px"> *@
            @*     <Template Context="contract"> *@
            @*         @contract.Template: $1$ TODO #1# *@
            @*     </Template> *@
            @* </RadzenDataGridColumn> *@
        }
    </Columns>
</EditableView>

@code {
    [Parameter] public ContractsFilter? Filter { get; set; }
    [Parameter] public bool BriefView { get; set; }
    [Parameter] public bool AllowSelect { get; set; }
    [Parameter] public Action<ContractListView>? ValueChanged { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool EnableActions { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        Filter ??= new();
    }

    string GetLookIntoHref(ContractListView c) => $"/static-data/contracts/{c.ContractId}";

    private void OnRowSelected(ContractListView c) => ValueChanged?.Invoke(c);

}