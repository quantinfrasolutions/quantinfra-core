@using QuantInfra.Common.Interfaces.Api.StaticData

<RadzenFormField Text="Id" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenNumeric TValue="int?" @bind-Value=@Filter.TemplateId @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>
<RadzenFormField Text="Name" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.Name @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public ContractTemplatesFilter? Filter { get; set; }
    [Parameter] public EventCallback<ContractTemplatesFilter>? FilterChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Filter == null)
        {
            Filter = new ContractTemplatesFilter();
            await OnPropUpdated();
        }
    }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}