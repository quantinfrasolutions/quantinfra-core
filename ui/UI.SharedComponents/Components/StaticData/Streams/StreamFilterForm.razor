@using QuantInfra.Common.Interfaces.Api.StaticData
@using UI.SharedComponents.Components.StaticData.Contracts

<RadzenFormField Text="IDs (comma-separated)" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox Value=@(string.Join(',', Filter.StreamIds ?? new()))
                   ValueChanged=@OnStreamIdsChanged />
</RadzenFormField>
<RadzenFormField Text="ContractId" Variant="Variant.Text" Style="min-width: 180px;">
    <ContractsSelector TValue="int?" @bind-Value=@Filter.ContractId Required="false" />
</RadzenFormField>
<RadzenFormField Text="Ticker" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.Ticker @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public StreamsFilter? Filter { get; set; }
    [Parameter] public EventCallback<StreamsFilter>? FilterChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Filter == null)
        {
            Filter = new();
            await OnPropUpdated();
        }
    }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
    
    private Task OnStreamIdsChanged(string arg)
    {
        Filter.StreamIds = arg.Split(',')
            .Select(s => int.TryParse(s.Trim(), out var i) ? i : 0)
            .Where(s => s != 0)
            .ToList();
        
        return OnPropUpdated();
    }
}