@using QuantInfra.Sdk.StaticData
@using UI.SharedComponents.Base

@typeparam TValue

<SearchSelector TKey="int?" 
                TItem="Broker" 
                Text="Broker"
                Required=@Required
                @ref=_selector
                KeySelector="@(c => c.BrokerId)"
                LabelSelector="@(c => c.Name)"
                Value=@(Value as int?)
                ValueChanged=@OnValueChanged
                SomethingSelected="@(Value is long? && Value as long? != 0)"
                Disabled=@Disabled
                >
                    
    <Selector>
        @* @bind-Id:after="@(() => ValueChanged.InvokeAsync(Value))" *@
        @* @bind-Label:after="@(() => LabelChanged.InvokeAsync(Label))" *@
        <BrokersView BriefView="true" AllowSelect="true" ValueChanged=@_selector.OnSomethingSelected Variant="Variant.Flat"/>
    </Selector>
</SearchSelector>

@code {
    private SearchSelector<int?, Broker> _selector;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    
    [Parameter] public string Label { get; set; }
    [Parameter] public EventCallback<string> LabelChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    [Parameter] public bool Disabled { get; set; }
    
    private async Task OnValueChanged(int? value)
    {
        if (!Required || (Required && value != null))
        {
            Value = (TValue)(object)value;
            await ValueChanged.InvokeAsync(Value);
        }
    }
}