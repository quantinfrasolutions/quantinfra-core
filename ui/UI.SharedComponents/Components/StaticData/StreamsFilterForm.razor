@using QuantInfra.Common.Interfaces.Api.StaticData

<RadzenFormField Text="Ticker" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.Ticker @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>
@* Exchnages Selector *@

@code {
    [Parameter, EditorRequired] public StreamsFilter Filter { get; set; }
    [Parameter] public EventCallback<StreamsFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    
    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}
