@using QuantInfra.Sdk.StaticData
@using UI.Interfaces.StaticData
@using UI.SharedComponents.Base

@inject IUiStaticDataRepository Repository

@typeparam TValue

<SearchSelector TItem="Broker"
                TValue="int"
                ValueProperty="@nameof(Broker.BrokerId)"
                ValueSelector="@(a => a.BrokerId)"
                SearchFunc="@DoSearch"
                Value="@NullableUtils.AsInt(Value)"
                ValueChanged="@(v => NullableUtils.OnInnerValueChanged(v, Required, ValueChanged))"
                IsRequired="@Required"
                @bind-Loading="@_isLoading"
                PreloadData="true">
    <ValueTemplate Context="broker">
        (@broker.BrokerId) @broker.Name
    </ValueTemplate>
</SearchSelector>

@code {
    private bool _isLoading;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Task<IEnumerable<Broker>> DoSearch(string? filter)
    {
        return Repository.GetBrokers(new() { Limit = int.MaxValue });
    }
}