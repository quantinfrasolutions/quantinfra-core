@using QuantInfra.Common.Interfaces.Api.StaticData
@using UI.Interfaces.StaticData
@using QuantInfra.Sdk.StaticData
@using UI.SharedComponents.Base

@inject IUiCurrenciesRepository Repository

<EditableView TItem="Currency"
              TFilter="CurrencyFilter"
              EmptyText="No currencies found"
              SearchFunc=@Repository.GetCurrencies
              Filter=@Filter
              AllowSelectRow=@AllowSelect
              SelectionMode="DataGridSelectionMode.Single"
              SelectAction=@OnRowSelected
              Variant=@Variant>
    <SearchForm>
        <CurrenciesFilterForm @bind-Filter=@Filter />
    </SearchForm>
    <Columns>
        <RadzenDataGridColumn TItem="Currency" Property=@nameof(Currency.CurrencyId) Width="100px" Title="Id" />
        <RadzenDataGridColumn TItem="Currency" Property="Asset.Name" Width="200px" Title="Name" />
        @if (!BriefView)
        {
            <RadzenDataGridColumn TItem="Currency" Property=@nameof(Currency.Decimals) Width="100px" Title="Decimals"/>
        }
    </Columns>
</EditableView>

@code {
    [Parameter] public CurrencyFilter? Filter { get; set; }
    [Parameter] public bool BriefView { get; set; }
    [Parameter] public bool AllowSelect { get; set; }
    [Parameter] public Action<Currency>? ValueChanged { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        Filter ??= new();
    }

    private void OnRowSelected(Currency c) => ValueChanged?.Invoke(c);

}