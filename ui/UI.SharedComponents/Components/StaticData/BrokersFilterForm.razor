@using QuantInfra.Common.Interfaces.Api.StaticData

@code {
    [Parameter, EditorRequired] public BrokersFilter? Filter { get; set; }
    [Parameter] public EventCallback<BrokersFilter>? FilterChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Filter == null)
        {
            Filter = new();
            await OnPropUpdated();
        }
    }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}