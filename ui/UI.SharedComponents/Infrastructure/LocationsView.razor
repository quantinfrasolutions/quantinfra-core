@using Common.Infrastructure.Abstractions
@using QuantInfra.Common.Infrastructure.Abstractions
@using UI.Interfaces
@using UI.Interfaces.Infrastructure
@using UI.SharedComponents.Base

@inject IUiInfrastructureRepository Repository

<EditableView TItem="Location"
             TFilter="EmptyFilter"
             EmptyText="No locations set up"
             SearchFunc="@Repository.GetLocations"
             Filter="@Filter"
             RunSearchImmediately="true"
             SearchButtonText="Refresh"
             Variant=@Variant
             HideActionsColumn=@(!EnableActions)
             AllowSelectRow=@AllowSelect
             SelectionMode="DataGridSelectionMode.Single"
             SelectAction=@ValueChanged>
    <SearchForm />
    <Columns>
        <RadzenDataGridColumn TItem="Location" Property=@nameof(Location.Name) Width="120px" Title="Id" />
    </Columns>
</EditableView>

@code {
    [Parameter] public EmptyFilter Filter { get; set; } = new();
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool AllowEdit { get; set; }
    [Parameter] public bool AllowSelect { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool EnableActions { get; set; } = true;
    [Parameter] public EventCallback<Location> ValueChanged { get; set; }
}