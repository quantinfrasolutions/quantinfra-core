@using QuantInfra.Sdk.Accounting
@using Vizor.ECharts

<RadzenStack Gap="1rem">
    <RadzenRow>
        <RadzenColumn Size="12">
            @if (_chartOptions is not null)
            {
                <RadzenCard>
                    <Vizor.ECharts.EChart Options="@_chartOptions" Width="auto" Height="400px" />
                </RadzenCard>
            }
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    private ChartOptions? _chartOptions;
    
    [Parameter] public IReadOnlyList<SharePriceHistory>? SingleAccount { get; set; }
    [Parameter] public IReadOnlyDictionary<int, IReadOnlyList<SharePriceHistory>>? MultipleAccounts { get; set; }
    
    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        BuildChart();
    }

    private void BuildChart()
    {
        _chartOptions = new()
        {
            Grid = new()
            {
                Left = 0,
                Right = 0,
                Top = 0,
                Bottom = 0,
            }
        };
        
        _chartOptions.XAxis = new()
        {
            Type = AxisType.Time,
            BoundaryGap = false,
        };

        if (SingleAccount is not null)
        {
            _chartOptions.Tooltip = new()
            {
                Trigger = TooltipTrigger.Axis,
            };

            _chartOptions.YAxisList =
            [
                new YAxis()
                {
                    Type = AxisType.Value,
                    Name = "Yield, %",
                    Id = "yield"
                },
                new YAxis()
                {
                    Type = AxisType.Value,
                    Position = LeftOrRight.Right,
                    Name = "Daily return, %",
                    Id = "returns",
                },
            ];

            _chartOptions.Series =
            [
                new LineSeries()
                {
                    YAxisIndex = 0,
                    Symbol = "none",
                    Name = "Yield",
                    Data = new List<SeriesData<DateTime, decimal>>(SingleAccount
                        .Select(i => new SeriesData<DateTime, decimal>(
                            i.Dt.ToDateTimeUtc(),
                            Math.Round((i.SharePrice - 1) * 100, 2)
                        )
                    ))
                },
                new BarSeries()
                {
                    YAxisIndex = 1,
                    Name = "Daily return",
                    Data = new List<SeriesData<DateTime, decimal>>(SingleAccount
                        .Select(i => new SeriesData<DateTime, decimal>(
                            i.Dt.ToDateTimeUtc(),
                            Math.Round(i.DailyReturn * 100, 2)
                        )
                    ))
                },
            ];
        }

        else if (MultipleAccounts is not null)
        {
            _chartOptions.Tooltip = new()
            {
                Trigger = TooltipTrigger.Item,
            };

            _chartOptions.YAxis = new YAxis()
            {
                Type = AxisType.Value,
                Name = "Yield, %",
                Id = "yield"
            };

            _chartOptions.Series = MultipleAccounts.Select(kv => (ISeries)new LineSeries()
            {
                Symbol = "none",
                Name = kv.Key.ToString(),
                Data = new List<SeriesData<DateTime, decimal>>(kv.Value
                    .Select(i => new SeriesData<DateTime, decimal>(
                            i.Dt.ToDateTimeUtc(),
                            Math.Round((i.SharePrice - 1) * 100, 2)
                        )
                    ))
            }).ToList();
        }
    }
}