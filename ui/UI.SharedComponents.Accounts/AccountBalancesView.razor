@using UI.Interfaces.Accounts
@using QuantInfra.Common.Interfaces.Api.Accounts
@using Radzen
@using UI.SharedComponents.Base
@using UI.SharedComponents.Components.Accounts

@inject IUiAccountsRepository Repository

<EditableView TItem="BalanceModel"
             TFilter="int"
             EmptyText="No balances"
             SearchFunc="@Repository.GetBalances"
             Filter="@AccountId"
             RunSearchImmediately=@RunSearchImmediately
             SearchButtonText="Refresh"
             HideRefreshButton=@HideRefreshButton
             Variant=@Variant
             @ref=_view>
    <SearchForm />
    <CreateButton>
        <NewBalanceOperationDialog ShowButton="true" AccountId=@AccountId AccountCurrencyId=@AccountCurrencyId HideAccountSelector="true" OnCompleted=@(() => _view.RunSearch())  />
    </CreateButton>
    <Columns>
        <RadzenDataGridColumn TItem="BalanceModel" Property=@nameof(BalanceModel.AssetId) Width="80px" Title="Id" />
        <RadzenDataGridColumn TItem="BalanceModel" Property=@nameof(BalanceModel.AssetName) Width="100px" Title="Asset" />
        <RadzenDataGridColumn TItem="BalanceModel" Property=@nameof(BalanceModel.Balance) Width="150px" Title="Balance" />
    </Columns>
</EditableView>

@code {
    [Parameter, EditorRequired] public int AccountId { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public int AccountCurrencyId { get; set; }
    [Parameter] public bool HideRefreshButton { get; set; }
    [Parameter] public bool RunSearchImmediately { get; set; }
    
    private EditableView<BalanceModel, int> _view;
    
    public Task Refresh() => _view.RunSearch();
}