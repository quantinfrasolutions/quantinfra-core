@using NodaTime
@using QuantInfra.Common.Interfaces.Api
@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Sdk.Accounts
@using UI.Interfaces.Accounts
@using UI.SharedComponents.Accounts.Balances
@using UI.SharedComponents.Accounts.Reporting
@inject IUiAccountsRepository Repository

@if (_tradeFilter != null && _orderFilter != null)
{
    <RadzenStack Gap="1rem">
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenCard>
                    <RadzenButton Text="Refresh" Variant="Variant.Text" 
                                  ButtonStyle="ButtonStyle.Primary" Click=@Refresh IsBusy=@_isLoading/>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenAccordion Multiple="true">
                    <Items>
                        <RadzenAccordionItem Text="Positions" Icon="browse_activity" @bind-Selected=@_positionsExpanded>
                            <ActivePositionsView Account=@Account
                                                 HideFilter="true"
                                                 HideAccount="true"
                                                 RunSearchImmediately="true"
                                                 Variant="Variant.Flat"
                                                 AutoRefresh="false"
                                                 ReloadRequested=@Refresh
                                                 HideRefreshButton="true"
                                                 @ref=_positions />
                        </RadzenAccordionItem>
                        <RadzenAccordionItem Text="Orders" Icon="request_quote" @bind-Selected=@_ordersExpanded>
                            <ActiveOrdersView Account=@Account
                                              ShowFilter="false"
                                              HideAccountFilter="true"
                                              ShowAccountColumn=@(Account.AccountType == AccountType.BrokerAccount)
                                              ShowBrokerAccountColumn=@(Account.AccountType == AccountType.StrategySubAccount || Account.AccountType == AccountType.ExecutableSubAccount)
                                              RunSearchImmediately="true"
                                              AllowNewOrder="true"
                                              Variant="Variant.Flat"
                                              AutoRefresh="false"
                                              ReloadRequested=@Refresh
                                              HideRefreshButton="true"
                                              @ref=_orders />
                        </RadzenAccordionItem>
                        <RadzenAccordionItem Text="Balances" Icon="account_balance_wallet" @bind-Selected=@_balancesExpanded>
                            <AccountBalancesView AccountId=@Account.AccountId
                                                 RunSearchImmediately="true"
                                                 HideRefreshButton="true"
                                                 Variant="Variant.Flat"
                                                 @ref=_balances />
                        </RadzenAccordionItem>
                        <RadzenAccordionItem Text="Recent activity" Icon="history" @bind-Selected=@_historyExpanded>
                            <RadzenStack>
                                <RadzenRow>
                                    <RadzenColumn Size="6">
                                        @if (_tradeFilter != null)
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Text="Trades"/>
                                            <TradesHistory Filter=@_tradeFilter
                                                           Columns=@(new List<string>() { "Dt", "ClOrdId", "OrderId", "Contract", "Side", "Volume", "Price" })
                                                           HideRefreshButton="true"
                                                           ShowFilter="false"
                                                           RunSearchImmediately="true"
                                                           Variant="Variant.Flat"
                                                           AllowSorting="true"
                                                           DefaultOrderByDescending="Dt"
                                                           @ref=_trades
                                                           Repository="@Repository"/>
                                        }
                                    </RadzenColumn>
                                    <RadzenColumn Size="6">
                                        @if (_orderFilter != null)
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Text="Orders"/>
                                            <OrdersHistory Filter=@_orderFilter
                                                           Columns=@(new List<string>() { "ClOrdId", "OrderId", "TransactTime", "Contract", "OrdType", "Side", "OrdQty", "Price", "StopPx", "OrdStatus", "LeavesQty", "RejectReason", "RejectText" })
                                                           HideRefreshButton="true"
                                                           HideFilter="true"
                                                           RunSearchImmediately="true"
                                                           Variant="Variant.Flat"
                                                           DefaultOrderByDescending="TransactTime"
                                                           @ref=_ordersHistory/>
                                        }
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenStack>
                        </RadzenAccordionItem>
                    </Items>
                </RadzenAccordion>
            </RadzenColumn>
        </RadzenRow>
    </RadzenStack>
}

@code {
    [Parameter, EditorRequired] public AccountRecordV6 Account { get; set; }
    
    private bool _positionsExpanded = true, _ordersExpanded = true, _balancesExpanded = true, _historyExpanded = false;
    
    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        
        var now = SystemClock.Instance.GetCurrentInstant().Minus(Duration.FromMinutes(5));
        _tradeFilter = new() { AccountId = Account.AccountId, FromDt = now.ToApiFormat(), };
        _orderFilter = new() { AccountId = Account.AccountId, FromDt = now.ToApiFormat(), };
    }

    private bool _isLoading;
    private ActivePositionsView _positions;
    private ActiveOrdersView _orders;
    private TradeFilter? _tradeFilter;
    private OrderFilter? _orderFilter;
    private TradesHistory _trades;
    private OrdersHistory _ordersHistory;
    private AccountBalancesView _balances;

    private async Task Refresh()
    {
        var now = SystemClock.Instance.GetCurrentInstant().Minus(Duration.FromMinutes(5)).ToApiFormat();
        _tradeFilter!.FromDt = now;
        _orderFilter!.FromDt = now;
        try
        {
            _isLoading = true;
            await Task.WhenAll(
                Task.Run(_orders.Refresh),
                Task.Run(_positions.Refresh),
                Task.Run(_trades.Refresh),
                Task.Run(_ordersHistory.Refresh),
                Task.Run(_balances.Refresh)
            );
        }
        catch {}
        finally
        {
            _isLoading = false;
        }
    }
}