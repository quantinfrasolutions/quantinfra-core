@using QuantInfra.Common.Interfaces.Api
@using QuantInfra.Common.Interfaces.Api.Accounts
@using QuantInfra.Sdk.Trading.Orders
@using UI.SharedComponents.StaticData.Contracts

@if (!HideAccountSelector)
{
    <AccountsSelector @bind-Value=@Filter.AccountId Required="false" />
}
<ContractsSelector TValue="int?" @bind-Value=@Filter.ContractId />
<RadzenFormField Text="From" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24" 
                      Value=@(Filter.FromDt?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.FromDt = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="To" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDatePicker TValue="DateTime?" ShowTime="true" ShowSeconds="true" HourFormat="24"
                      Value=@(Filter.ToDt?.ToDateTimeUtc())
                      ValueChanged=@(dt => Filter.ToDt = dt.ParseInput())
                      Disabled="@Disabled" />
</RadzenFormField>

<RadzenFormField Text="OrderId" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenNumeric TValue="long?" @bind-Value=@Filter.OrderId Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="ExternalId" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox @bind-Value=@Filter.ExternalId Disabled="@Disabled" />
</RadzenFormField>
<RadzenFormField Text="OrdStatus" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDropDown AllowClear="true" Multiple="false" Data=@(Enum.GetValues(typeof(OrdStatus)).Cast<Enum>()) @bind-Value=@Filter.OrdStatus />
</RadzenFormField>
<RadzenFormField Text="ExecType" Variant="@Variant.Text" Style="min-width: 180px;">
    <RadzenDropDown AllowClear="true" Multiple="false" Data=@(Enum.GetValues(typeof(ExecType)).Cast<Enum>()) @bind-Value=@Filter.ExecType />
</RadzenFormField>
    

@code {
    [Parameter, EditorRequired] public OrderFilter Filter { get; set; }
    [Parameter] public EventCallback<OrderFilter>? FilterChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HideAccountSelector { get; set; }
    
    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}