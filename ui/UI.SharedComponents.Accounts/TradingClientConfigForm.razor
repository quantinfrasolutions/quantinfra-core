@using QuantInfra.Common.Interfaces.Api.Accounts
@using Radzen
@using UI.SharedComponents.Infrastructure
<RadzenTemplateForm TItem="CreateTradingClientConfigRequest" Data="Data" Style="width: 100%;">
    <RadzenStack AlignItems="AlignItems.Stretch">
        <RadzenRow>
            @if (ReadOnly)
            {
                <RadzenFormField Variant="Variant.Text" Text="Execution service">
                    <RadzenTextBox @bind-Value=@Data.ExecutionServiceName Disabled="true" />
                </RadzenFormField>
            }
            else
            {
                <ExecutionServiceSelector TValue="string" @bind-Value=@Data.ExecutionServiceName />
            }
        </RadzenRow>
        <RadzenRow>
            <RadzenFormField Variant="Variant.Text" Text="External account ID">
                <RadzenTextBox @bind-Value=@Data.ExternalAccountId Disabled=@(ReadOnly) />
            </RadzenFormField>
        </RadzenRow>
        <RadzenRow>
            <RadzenFormField Variant="Variant.Text" Text="Trading client class name">
                <RadzenTextBox @bind-Value=@Data.TradingClientClassName Disabled=@(ReadOnly) />
            </RadzenFormField>
        </RadzenRow>
        @if (!ReadOnly)
        {
            <RadzenRow>
                <RadzenFormField Variant="Variant.Text" Text="API Secret">
                    <RadzenTextBox @bind-Value=@Data.TradingClientSecret Disabled=@(ReadOnly) />
                </RadzenFormField>
            </RadzenRow>
        }
        <RadzenRow>
            <RadzenFormField Variant="Variant.Text" Text="Params JSON">
                <RadzenTextArea @bind-Value=@Data.TradingClientParamsSerialized Disabled=@(ReadOnly) />
            </RadzenFormField>
        </RadzenRow>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter, EditorRequired] public int AccountId { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public CreateTradingClientConfigRequest Data { get; set; }

    protected override void OnParametersSet()
    {
        Data ??= new()
        {
            AccountId = AccountId,
        };
    }

}