@using QuantInfra.Common.Interfaces.Api.Accounts
@using Radzen
@using UI.Interfaces.Accounts

@inject DialogService DialogService
@inject IUiAccountsRepository AccountsRepository

@if (Account.TradingClientConfig == null)
{
    <RadzenButton ButtonStyle="ButtonStyle.Primary" Text="Configure" Variant="Variant.Text" Click=@Create IsBusy=@_isLoading />
}
else
{
    <RadzenButton ButtonStyle="ButtonStyle.Danger" Text="Delete" Variant="Variant.Text" Click=@Delete IsBusy=@_isLoading />
}

@code {
    private bool _isLoading;
    [Parameter] public AccountListModel Account { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }

    private async Task Create()
    {
        DialogService.Open<TradingClientConfigDialog>(
            "Configure trading client",
            new Dictionary<string, object>()
            {
                { "AccountId", Account.AccountId },
                { "OnCompleted", new EventCallback(this, OnClientConfigCreated) },
            }
        );
    }

    private async Task Delete()
    {
        var res = await DialogService.Confirm(
            "Please confirm deleting trading configuration for the broker account", 
            "Delete configuration",
            new ConfirmOptions
            {
                OkButtonText = "Delete",
                CancelButtonText = "Keep",
            }
        );

        if (res == true)
        {
            _isLoading = true;
            try
            {
                await AccountsRepository.DeleteTradingAccountConfig(Account.AccountId);
                await OnCompleted.InvokeAsync();
            }
            finally
            {
                _isLoading = false;
            }
        }
    }

    private Task OnClientConfigCreated()
    {
        DialogService.Close();
        return OnCompleted.InvokeAsync();
    }

}