@using QuantInfra.Common.Interfaces.Api.Backtesting

@if (Filter is not null)
{
    <RadzenFormField Text="Test Id" Variant="Variant.Text" Style="min-width: 180px;">
        <RadzenTextBox Value=@Filter.TestId.ToString() 
                       ValueChanged=@(s => Filter!.TestId = string.IsNullOrEmpty(s) ? null : Guid.Parse(s))
                       Disabled=@Disabled />
    </RadzenFormField>
    <RadzenFormField Text="Action" Variant="Variant.Text" Style="min-width: 180px;">
        <RadzenTextBox @bind-Value=@Filter.Action 
                       @bind-Value:after=@OnPropUpdated 
                       Disabled=@Disabled />
    </RadzenFormField>
}

@code {
    [Parameter, EditorRequired] public TestUnitsFilter? Filter { get; set; }
    [Parameter] public EventCallback<TestUnitsFilter>? FilterChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Filter == null)
        {
            Filter = new();
            await OnPropUpdated();
        }
    }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}