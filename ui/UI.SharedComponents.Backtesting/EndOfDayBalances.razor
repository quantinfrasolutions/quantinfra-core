@using Common.Accounting
@using Common.Trading.Positions
@using UI.Interfaces

@inject IExportService ExportService

<RadzenDataGrid TItem="BalanceValue"
                Data=@Aggregated
                EmptyText="No balances found"
                AllowSorting="true"
                AllowFiltering="true"
                AllowVirtualization="true"
                RowRender=@OuterGridRowRender>
    <Columns>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.AccountId)) Title="StrategyId" Width="120px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.CurrencyId)) Title="CurrencyId" Width="120px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.Dt)) Title="Dt" Width="220px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.CashBalance)) Title="Cash balance" Width="160px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.Holdings)) Title="Holdings" Width="160px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.UnrealizedPnL)) Title="Unrealized PnL" Width="160px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.FuturesVariationMargin)) Title="Futures VM" Width="160px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.TotalValue)) Title="Value" Width="160px"/>
        <RadzenDataGridColumn Property=@(nameof(BalanceValue.FxRate)) Title="FxRate" Width="160px"/>
        <RadzenDataGridColumn MinWidth="0"/>
    </Columns>
    <Template Context="agg">
        <RadzenDataGrid TItem="BalanceValue"
                        Data=@Data.Where(x => x.AccountId == agg.AccountId && x.Dt == agg.Dt)
                        EmptyText="No balances found"
                        RowRender=@InnerGridRowRender>
            <Columns>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.CurrencyId)) Title="CurrencyId" Width="120px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.CashBalance)) Title="Cash balance" Width="160px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.Holdings)) Title="Holdings" Width="160px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.UnrealizedPnL)) Title="Unrealized PnL" Width="160px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.FuturesVariationMargin)) Title="Futures VM" Width="160px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.TotalBalance)) Title="Total" Width="160px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.TotalValue)) Title="Value" Width="160px"/>
                <RadzenDataGridColumn Property=@(nameof(BalanceValue.FxRate)) Title="FxRate" Width="160px"/>
                <RadzenDataGridColumn MinWidth="0"/>
            </Columns>
            <Template Context="balance">
                <EndOfDayPositions Data=@Positions.Where(p => p.AccountId == agg.AccountId && p.CloseDt == agg.Dt).ToList() 
                                   Values=@PositionValues.Where(p => p.AccountId == agg.AccountId && p.Dt == agg.Dt).ToList() />
            </Template>
        </RadzenDataGrid>
    </Template>
</RadzenDataGrid>

@code
{
    [Parameter, EditorRequired] public IReadOnlyCollection<BalanceValue> Aggregated { get; set; }
    [Parameter, EditorRequired] public IReadOnlyCollection<BalanceValue> Data { get; set; }
    [Parameter, EditorRequired] public IReadOnlyCollection<Position> Positions { get; set; }
    [Parameter, EditorRequired] public IReadOnlyCollection<PositionValue> PositionValues { get; set; }

    private Task Export(string type) => type switch
    {
        "csv" => ExportService.ToCsv(Data.AsQueryable(), "eod-positions"),
        "excel" => ExportService.ToExcel(Data.AsQueryable(), "eod-positions"),
        _ => Task.CompletedTask
    };

    void OuterGridRowRender(RowRenderEventArgs<BalanceValue> args)
    {
        args.Expandable = args.Data.CashBalance != 0 || args.Data.UnrealizedPnL != 0 || args.Data.FuturesVariationMargin != 0;
    }
    
    void InnerGridRowRender(RowRenderEventArgs<BalanceValue> args)
    {
        args.Expandable = args.Data.UnrealizedPnL != 0 || args.Data.FuturesVariationMargin != 0;
    }
}