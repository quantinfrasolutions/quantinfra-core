@using System.Text.Json
@using Common.Backtesting
@using Common.Strategies
@using QuantInfra.Common.Strategies.Api

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Single strategy">
            <RadzenTemplateForm TItem="CreateStrategyRequest"
                                Data=@Value>
                <RadzenStack Gap="1rem">
                    <RadzenRow>
                        <RadzenFormField Text="Name" Variant="Variant.Text">
                            <RadzenTextBox @bind-Value=@Value.Name></RadzenTextBox>
                        </RadzenFormField>
                        <RadzenTextArea Placeholder="Insert JSON" ValueChanged=@OnJsonUpdated />
                    </RadzenRow>
                </RadzenStack>
            </RadzenTemplateForm>
        </RadzenTabsItem>
        <RadzenTabsItem Text="Multiple strategies" Disabled="true">
            <RadzenDataGrid TItem="CreateStrategyRequest">
                <Columns>
                    <RadzenDataGridColumn Title="Name" Property=@nameof(CreateStrategyRequest.Name) Width="200px" />
                    <RadzenDataGridColumn Title="Class" Property=@nameof(CreateStrategyRequest.ClassName) Width="300px" />
                    <RadzenDataGridColumn Title="Params">
                        <Template Context="strategy">
                
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    private List<StrategyTypeDescription> _strategyClasses;
    private string? _error;
    
    [Parameter, EditorRequired] public CreateStrategyRequest Value { get; set; }
    [Parameter] public EventCallback<CreateStrategyRequest> ValueChanged { get; set; }
    
    [Inject] ITestServer TestServer { get; set; }
    

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _strategyClasses = await TestServer.GetStrategiesAsync();
    }

    private void OnJsonUpdated(string data)
    {
        try
        {
            _error = null;
            Value = JsonSerializer.Deserialize<CreateStrategyRequest>(data);
            ValueChanged.InvokeAsync(Value);
        }
        catch (Exception e)
        {
            _error = e.Message;
        }
    }

}