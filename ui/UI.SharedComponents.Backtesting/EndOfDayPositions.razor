@using Common.MarketData
@using Common.Trading.Positions
@using Common.Utils
@using NodaTime
@using UI.Interfaces

@inject IExportService ExportService

<RadzenDataGrid Data=@_data
                EmptyText="No positions found"
                AllowSorting="true"
                AllowFiltering="true"
                AllowVirtualization="true">
    <HeaderTemplate>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="1rem;" Wrap="FlexWrap.Wrap" Style="width: 100%;">
            <RadzenButton Icon="table_rows_narrow" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Click="@(args => Export("excel"))" />
            <RadzenButton Icon="csv" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Click="@(args => Export("csv"))" />
        </RadzenStack>
    </HeaderTemplate>
    <Columns>
        <RadzenDataGridColumn Property=@(nameof(Joined.AccountId)) Title="StrategyId" Width="100px"/>
        <RadzenDataGridColumn Property=@(nameof(Joined.PositionId)) Title="PositionId" Width="120px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.ContractId) Title="ContractId" Width="120px"/>
        <RadzenDataGridColumn Property=@(nameof(Joined.StrategyPositionId)) Title="StrategyPositionId" Width="100px"/>

        <RadzenDataGridColumn Property=@(nameof(Joined.OpenDt)) Title="OpenDt" Width="180px" FilterValue=@(_openDt.HasValue ? Instant.FromDateTimeUtc(DateTime.SpecifyKind(_openDt.Value, DateTimeKind.Utc)) : null)>
            <FilterTemplate>
                <RadzenDatePicker @bind-Value=@_openDt Style="width:100%;" AllowClear="true" DateFormat="d" InputAttributes="@(new Dictionary<string, object>() { { "aria-label", "filter by Hire Date" } })"/>
            </FilterTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property=@nameof(Joined.SignedVolume) Title="Volume" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.TotalOpenPayments) Title="TotalOpenPayments" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.OpenPrice) Title="OpenPx" Width="100px"/>

        <RadzenDataGridColumn Property=@(nameof(Joined.HistoryOpenDt)) Title="OpenDt" Width="180px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.TotalSettlPayments) Title="TotalSettlPayments" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.SettlPrice) Title="SettlPx" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.TotalSettlPaymentsInAccountCcy) Title="TotalSettlPayments(Acc)" Width="100px"/>

        <RadzenDataGridColumn Property=@(nameof(Joined.CloseDt)) Title="CloseDt" Width="180px" FilterValue=@(_closeDt.HasValue ? Instant.FromDateTimeUtc(DateTime.SpecifyKind(_closeDt.Value, DateTimeKind.Utc)) : null)>
            <FilterTemplate>
                <RadzenDatePicker @bind-Value=@_closeDt Style="width:100%;" AllowClear="true" DateFormat="d" InputAttributes="@(new Dictionary<string, object>() { { "aria-label", "filter by Hire Date" } })"/>
            </FilterTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property=@nameof(Joined.ClosePrice) Title="ClosePx" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.ValuePrice) Title="ValuePx" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.FloatingPnL) Title="Floating PnL" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.TotalFloatingPnL) Title="Total FPnL" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.SignedValue) Title="Value" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.SignedValueInAccountCcy) Title="Value (acc)" Width="100px"/>
        <RadzenDataGridColumn Property=@nameof(Joined.EquityValueInAccountCcy) Title="Equity" Width="100px"/>
        <RadzenDataGridColumn MinWidth="0"/>
    </Columns>
</RadzenDataGrid>

@code
{
    [Parameter, EditorRequired] public IReadOnlyCollection<Position> Data { get; set; }
    [Parameter, EditorRequired] public IReadOnlyCollection<PositionValue> Values { get; set; }

    private List<Joined>? _data;
    
    private DateTime? _openDt, historyOpenDt, _closeDt;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _data = Data.FullOuterJoin(
            Values,
            l => new Key(l.OpenTradeId, l.CloseDt!.Value),
            r => new Key(r.PositionId, r.Dt),
            (l, r, k) => new Joined(k.PositionId, l, r)
        ).ToList();
    }

    readonly struct Key
    {
        public Key(long positionId, Instant dt)
        {
            PositionId = positionId;
            Dt = dt;
        }

        public long PositionId { get; init; }
        public Instant Dt { get; init; }
    }

    class Joined(long positionId, Position? position, PositionValue? value)
    {
        public long PositionId { get; init; } = positionId;
        public int? AccountId { get; init; } = position?.AccountId ?? value?.AccountId;
        public string? StrategyPositionId { get; init; } = position?.StrategyPositionId;
        public int? ContractId { get; init; } = position?.ContractId;        
        public decimal? SignedVolume { get; init; } = position?.SignedVolume ?? value?.SignedValue;
        public decimal OpenPrice => Math.Abs(TotalOpenPayments / SignedVolume ?? 0);
        public decimal? TotalOpenPayments { get; init; } = position?.TotalOpenPayments;
        public Instant? OpenDt { get; init; } = position?.OpenDt;
        public Instant? HistoryOpenDt { get; init; } = position?.HistoryOpenDt;
        public decimal? TotalSettlPayments { get; init; } = position?.TotalSettlPayments;
        public decimal? TotalSettlPaymentsInAccountCcy { get; init; } = position?.TotalSettlPaymentsInAccountCcy;
        public decimal SettlPrice => Math.Abs(TotalSettlPayments / SignedVolume ?? 0);
        public decimal? ClosePrice { get; init; } = position?.ClosePrice;
        public decimal? ValuePrice { get; init; } = value?.Price;
        public Instant? CloseDt { get; init; } = position?.CloseDt ?? value?.Dt;
        public decimal? FloatingPnL { get; init; } = position?.FloatingPnL;
        public decimal? TotalFloatingPnL { get; init; } = position?.TotalFloatingPnL;
        public bool? IsSynthetic { get; init; } = position?.IsSynthetic;
        public long? ParentPositionId { get; init; } = position?.ParentPositionId;
        public decimal? SignedValue { get; init; } = value?.SignedValue;
        public decimal? SignedValueInAccountCcy { get; init; } = value?.SignedValueInAccountCcy;
        public decimal? EquityValueInAccountCcy { get; init; } = value?.EquityValueInAccountCcy;
    }
    
    private Task Export(string type) => type switch
    {
        "csv" => ExportService.ToCsv(_data.AsQueryable(), "eod-positions"),
        "excel" => ExportService.ToExcel(_data.AsQueryable(), "eod-positions"),
        _ => Task.CompletedTask
    };
}