@using Microsoft.AspNetCore.Components.Forms
@using QuantInfra.Connectors.Binance.Common
@using QuantInfra.Sdk.MarketData
@using UI.Interfaces.Binance
@using UI.SharedComponents.StaticData.Streams

@inject IUiBinanceMarketDataClient Client

<CreateItemForm TItem="BinanceUsdmMarketDataSubscriptionRequest"
                CreateFunc="@(req => Client.CreateSubscriptionAsync(Market, _clientName, req))"
                OnCompleted="@OnCompleted"
                @bind-IsLoading=@_isLoading>
    <Fields Context="request">
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenFormField Text="Client" Variant="Variant.Text">
                    <ChildContent>
                        <BinanceMdClientSelector @bind-Value=@_clientName Name="Name" Market="@Market" Disabled=@_isLoading />
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="Name" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenFormField Text="Symbol" Variant="Variant.Text">
                    <ChildContent>
                        <BinanceContractsSelector Market="@Market" @bind-Value="@request.Symbol" Disabled="@_isLoading" Required="true" />
                    </ChildContent>
                    <Helper>
                        <ValidationMessage For="@(() => request.Symbol)" class="rz-message rz-messages-error" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenFormField Text="Subscription type" Variant="Variant.Text">
                    <ChildContent>
                        <RadzenDropDown @bind-Value=@request.SubscriptionType Data=@(Enum.GetValues(typeof(SubscriptionType)).Cast<Enum>()) 
                                        Name="SubscriptionType" Disabled=@_isLoading/>
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="SubscriptionType" Text="Required" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenFormField Text="Stream" Variant="Variant.Text">
                    <ChildContent>
                        <StreamsSelector TValue="int?" @bind-Value=@request.StreamId Disabled=@_isLoading Required="false"/>
                    </ChildContent>
                    <Helper>
                        <ValidationMessage For="@(() => request.StreamId)" class="rz-message rz-messages-error" />
                    </Helper>
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
    </Fields>
</CreateItemForm>

@code {
    private bool _isLoading;
    private string _clientName;
    
    [Parameter, EditorRequired] public BinanceMarket Market { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }
}
