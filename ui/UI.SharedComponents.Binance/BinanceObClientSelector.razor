@using QuantInfra.Connectors.Binance.Common
@using UI.Interfaces.Binance

@inject IUiBinanceMarketDataClient Client

<SearchSelector TItem="string"
                TValue="string"
                ValueProperty=""
                ValueSelector="@(a => a)"
                SearchFunc="@DoSearch"
                Value="Value"
                ValueChanged="@ValueChanged"
                IsRequired="@Required"
                PreloadData="true"
                Name="@Name"
                @bind-Loading="@_isLoading">
    <ValueTemplate Context="item">
        @item
    </ValueTemplate>
</SearchSelector>

@code {
    private bool _isLoading;
    
    [Parameter] public string Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }
    
    [Parameter, EditorRequired] public BinanceMarket Market { get; set; }
    [Parameter] public string Name { get; set; }

    private Task<IEnumerable<string>> DoSearch(string? filter) =>
        Client.GetOrderBookClientsAsync();
}