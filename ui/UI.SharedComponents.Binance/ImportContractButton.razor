@using QuantInfra.Common.Interfaces.Api.Binance
<CreateItemButton TForm="ImportContractForm"
                  Text=""
                  Icon="download_2"
                  ShowButton="@ShowButton"
                  DialogTitle="Import contract"
                  OnCompleted="@OnCompleted"
                  FormParams="@(new()
                              {
                                  { "Contract", Contract } 
                              })"/>

@code {
    [Parameter] public bool ShowButton { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }
    [Parameter, EditorRequired] public BinanceContractListView Contract { get; set; }
}
