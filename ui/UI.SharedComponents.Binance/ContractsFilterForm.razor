@using QuantInfra.Common.Interfaces.Api.Binance

<RadzenFormField Text="Symbol" Variant="Variant.Text" Style="min-width: 180px;">
    <RadzenTextBox TValue="string?" @bind-Value=@Filter.Symbol @bind-Value:after=@OnPropUpdated Disabled=@Disabled />
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public BinanceContractsFilter? Filter { get; set; }
    [Parameter] public EventCallback<BinanceContractsFilter>? FilterChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (Filter == null)
        {
            Filter = new ();
            await OnPropUpdated();
        }
    }

    private Task OnPropUpdated() => FilterChanged?.InvokeAsync(Filter) ?? Task.CompletedTask;
}