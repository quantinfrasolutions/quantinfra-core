@using QuantInfra.Common.Interfaces.Api.Binance
@using QuantInfra.Connectors.Binance.Common
@using UI.Interfaces.Binance

@inject IUiBinanceStaticDataClient Client

<SearchSelector TItem="BinanceContractListView"
                TValue="string"
                ValueProperty="BinanceContract.Symbol"
                ValueSelector="@(a => a.BinanceContract.Symbol)"
                SearchFunc="@DoSearch"
                Value="Value"
                ValueChanged="@ValueChanged"
                IsRequired="@Required"
                @bind-Loading="@_isLoading">
    <ValueTemplate Context="item">
        @item.BinanceContract.Symbol
    </ValueTemplate>
</SearchSelector>

@code {
    private bool _isLoading;
    
    [Parameter] public string Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }
    
    [Parameter, EditorRequired] public BinanceMarket Market { get; set; }

    private Task<IEnumerable<BinanceContractListView>> DoSearch(string? filter) =>
        Client.GetContracts(new() { Symbol = filter, Market = Market });
}