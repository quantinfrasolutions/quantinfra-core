@page "/tests/history/{id:guid}"
@page "/tests/history/{id:guid}/summary"
@using NodaTime.Text
@using QuantInfra.Common.Interfaces.Api.Backtesting
@using UI.SharedComponents.Backtesting
@layout TestResultBase

<RadzenAccordion Style="width: 100%;">
    <Items>
        <RadzenAccordionItem Text="Test" @bind-Selected="@_firstPaneSelected">
            @if (TestResultBase?.TestUnit != null)
            {
                <RadzenTemplateForm Data=@TestResultBase.TestUnit>
                    <RadzenStack JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenRow>
                            <RadzenFormField Variant="Variant.Text" Text="Test ID" Style="min-width: 200px;">
                                <RadzenTextBox TValue="string" Value=@TestResultBase.TestUnit.TestId.ToString() Disabled="true"/>
                            </RadzenFormField>
                            <RadzenFormField Variant="Variant.Text" Text="Action" Style="min-width: 200px;">
                                <RadzenTextBox TValue="string" Value=@TestResultBase.TestUnit.Action Disabled="true"/>
                            </RadzenFormField>
                            <RadzenFormField Variant="Variant.Text" Text="Start" Style="min-width: 200px;">
                                <RadzenTextBox TValue="string" Value=@InstantPattern.ExtendedIso.Format(TestResultBase.TestUnit.Options.StartDt) Disabled="true"/>
                            </RadzenFormField>
                            <RadzenFormField Variant="Variant.Text" Text="End" Style="min-width: 200px;">
                                <RadzenTextBox TValue="string" Value=@InstantPattern.ExtendedIso.Format(TestResultBase.TestUnit.Options.EndDt) Disabled="true"/>
                            </RadzenFormField>
                        </RadzenRow>
                    </RadzenStack>
                </RadzenTemplateForm>
            }
        </RadzenAccordionItem>
        <RadzenAccordionItem Text="Parameters">
            @if (TestResultBase?.TestUnit != null)
            {
                <TestExecutorOptionsForm Disabled="true" Value="@TestExecutorOptionsModel.FromTestUnit(TestResultBase.TestUnit)" />
            }
        </RadzenAccordionItem>
        <RadzenAccordionItem Text="Options">
            @if (TestResultBase?.TestUnit != null)
            {
                <RadzenTextArea Value=@TestResultBase.TestUnit.Data Disabled="true" Style="width: 100%;" Rows="30" />
            }
        </RadzenAccordionItem>
        <RadzenAccordionItem Text="Contract overrides">
            @if (TestResultBase?.TestUnit != null)
            {
                if (TestResultBase.TestUnit.ContractOverride != null)
                {
                    <ContractOverrideForm Disabled="true" Contract=@ContractOverrideModel.FromSdk(TestResultBase.TestUnit.ContractOverride) />
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body2">No overrides</RadzenText>
                }
            }
        </RadzenAccordionItem>
    </Items>
</RadzenAccordion>

@code {
    private bool _firstPaneSelected = true;
    
    [Parameter] public Guid Id { get; set; }
    [CascadingParameter] public TestResultBase? TestResultBase { get; set; }
    
    protected override void OnInitialized()
    {
        TestResultBase!.Id = Id;
        TestResultBase.Path = "summary";
    }
}