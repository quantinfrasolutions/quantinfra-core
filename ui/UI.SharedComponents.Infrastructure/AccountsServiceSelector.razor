@using QuantInfra.Common.Infrastructure.Abstractions
@using UI.Interfaces.Infrastructure
@using UI.SharedComponents.Base

@inject IUiInfrastructureRepository Repository

@typeparam TValue

<SearchSelector TItem="AccountServiceInstance"
                TValue="string"
                ValueProperty="@nameof(AccountServiceInstance.Name)"
                ValueSelector="@(a => a.Name)"
                SearchFunc="@DoSearch"
                Value="@(Value as string)"
                ValueChanged="@(v => NullableUtils.OnInnerValueChanged(v, Required, ValueChanged))"
                IsRequired="@Required"
                @bind-Loading="@_isLoading"
                PreloadData="true">
    <ValueTemplate Context="accS">
        @accS.Name
    </ValueTemplate>
</SearchSelector>

@code {
    private bool _isLoading;
    
    [Parameter] public TValue Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Task<IEnumerable<AccountServiceInstance>> DoSearch(string? filter)
    {
        return Repository.GetAccountServiceInstances(new());
    }
}