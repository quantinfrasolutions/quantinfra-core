@using QuantInfra.Common.Interfaces.Api.Infrastructure
@using UI.Interfaces
@using UI.Interfaces.Infrastructure
@using UI.SharedComponents.Base

@inject IUiInfrastructureRepository Repository

<EditableView TItem="ExecutionServiceListView"
             TFilter="EmptyFilter"
             EmptyText="No locations set up"
             SearchFunc="@Repository.GetExecutionServiceInstances"
             Filter="@Filter"
             RunSearchImmediately="true"
             SearchButtonText="Refresh"
             Variant=@Variant
             HideActionsColumn=@(!EnableActions)
             AllowSelectRow=@AllowSelect
             SelectionMode="DataGridSelectionMode.Single"
             SelectAction=@ValueChanged>
    <SearchForm />
    <Columns>
        <RadzenDataGridColumn TItem="ExecutionServiceListView" Property=@nameof(ExecutionServiceListView.Name) Width="120px" Title="Name" />
        <RadzenDataGridColumn TItem="ExecutionServiceListView" Property=@nameof(ExecutionServiceListView.LocationName) Width="120px" Title="Location" />
        <RadzenDataGridColumn TItem="ExecutionServiceListView" Property=@nameof(ExecutionServiceListView.TradingClientsCount) Width="120px" Title="Trading clients" />
    </Columns>
</EditableView>

@code {
    [Parameter] public EmptyFilter Filter { get; set; } = new();
    [Parameter] public bool RunSearchImmediately { get; set; }
    [Parameter] public bool AllowEdit { get; set; }
    [Parameter] public bool AllowSelect { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public bool EnableActions { get; set; } = true;
    [Parameter] public EventCallback<ExecutionServiceListView> ValueChanged { get; set; }
}