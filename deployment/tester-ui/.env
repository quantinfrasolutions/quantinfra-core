nlog__targets__console__type=Console
nlog__targets__console__layout=${longdate} | ${level:uppercase=true:padding=-5} | ${logger} | ${message}${onexception:inner=${newline}${exception:format=tostring}}
nlog__rules__0__logger=Microsoft.AspNetCore.*
nlog__rules__0__maxLevel=info
nlog__rules__0__writeTo=
nlog__rules__0__final=true
nlog__rules__1__logger=Microsoft.*
nlog__rules__1__maxLevel=debug
nlog__rules__1__writeTo=
nlog__rules__1__final=true
nlog__rules__2__logger=Quartz.*
nlog__rules__2__maxLevel=debug
nlog__rules__2__writeTo=
nlog__rules__2__final=true
nlog__rules__3__logger=*
nlog__rules__3__minLevel=info
nlog__rules__3__writeTo=console

# When logging is enabled for a test unit, these presets will be used
nlog-testing__targets__test__type=File
nlog-testing__targets__test__layout=${longdate} | ${level:uppercase=true:padding=-5} | ${logger} | ${message}${onexception:inner=${newline}${exception:format=tostring}}
nlog-testing__rules__0__name=test
nlog-testing__rules__0__logger=*
nlog-testing__rules__0__minLevel=info
nlog-testing__rules__0__writeTo=test

# Set to true for the tester to create or update your main database 
app__MigrateMainDb=true

cli-wrapper__UseEnv=true
cli-wrapper__WorkingDirPath=./cli
cli-wrapper__StrategyTesterCliPath=./cli/StrategyTesterCli.dll

# You can add multiple dlls by adding the lines with new indices, e.g. __1, __2
# This is the path inside Docker container. If using multiple files, make sure you map it to the container's file system in docker-run.sh
local-test-server__StrategyAssembliesPaths__0=/strategies/<dll name>
# Use this to add custom backtesting workflows and metrics
# local-test-server__PluginAssembliesPaths__0=/extensions/CustomMetrics.dll

local-test-server__MarketDataPaths__0=/market-data/
local-test-server__WorkingDirectory=/results

# Set according to your installation
# If you don't use the static data database, comment all the entries below
db.main__Host=timescaledb
db.main__Port=5432
db.main__User=postgres
db.main__Password=postgres
db.main__Database=quantinfra
db.main__CommandTimeoutSec=60
db.main__ConnectionTimeoutSec=300
db.main__MaxPoolSize=5