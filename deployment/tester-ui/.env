# See https://quantinfra.gitbook.io/quantinfra-docs/installation/tester for instructions

PORT=8080 # Port for the app to use
#VERSION=latest


# STRATEGIES
# These are the paths inside the container. Do not forget to map the paths on your local computer in compose.paths.yaml
# If you use single project with strategies:
local-test-server__StrategyAssembliesPaths__0=/strategies/Strategies.dll

# For multiple projects
# local-test-server__StrategyAssembliesPaths__0=/strategies/project-1/Strategies-1.dll
# local-test-server__StrategyAssembliesPaths__1=/strategies/project-2/Strategies-2.dll


# MARKET DATA PATHS 
# If you use a single folder with market data:
local-test-server__MarketDataPaths__0=/market-data

# If you use multiple folders:
# local-test-server__MarketDataPaths__0=/market-data/source1
# local-test-server__MarketDataPaths__0=/market-data/source2


# PLUGINS
# Do not forget to map the paths in compose.paths.yaml
# local-test-server__PluginAssembliesPaths__0=/extensions/extension-project-1/CustomMetrics.dll


# OVERRIDE DATETIME FORMAT FOR CSV FILES
# local-test-server__DateTimeFormat: uuuu-MM-dd HH:mm:ss


# If you use --profile postgres, you can redefine default postgres settings here
#POSTGRES_VERSION=17
#POSTGRES_PORT=5432
#POSTGRES_DB=quantinfra
#POSTGRES_USER=postgres
#POSTGRES_PASSWORD=postgres

# Set according to your installation
db.main__Host=postgres
db.main__Port=5432
db.main__User=postgres
db.main__Password=postgres
db.main__Database=quantinfra
db.main__CommandTimeoutSec=60
db.main__ConnectionTimeoutSec=300
db.main__MaxPoolSize=5
#db.main__ConnectionStringExtras=

# Set to false if you don't want the tester to update your production database
app__MigrateMainDb=true

# When logging is enabled for a test unit, this layout will be used.
# If changing, do not forget to substitute NLog's $ with $$ to avoid problems with docker-compose.
nlog-testing__targets__test__layout=$${longdate} | $${level:uppercase=true:padding=-5} | $${logger} | $${message}$${onexception:inner=$${newline}$${exception:format=tostring}}