# Refer to https://quantinfra.gitbook.io/quantinfra-docs/installation/trading-engine#configuration

nlog__targets__console__type=Console
nlog__targets__console__layout=${date:universalTime=true:format=o}|${level:uppercase=true}|${logger}|${message}${onexception:inner= | ${exception:format=message,tostring}}
nlog__rules__0__logger=Microsoft.AspNetCore.*
nlog__rules__0__maxLevel=info
nlog__rules__0__writeTo=
nlog__rules__0__final=true
nlog__rules__1__logger=Microsoft.*
nlog__rules__1__maxLevel=debug
nlog__rules__1__writeTo=
nlog__rules__1__final=true
nlog__rules__2__logger=Quartz.*
nlog__rules__2__maxLevel=debug
nlog__rules__2__writeTo=
nlog__rules__2__final=true
nlog__rules__3__logger=*
# Change this to adjust the log level
nlog__rules__3__minLevel=info
nlog__rules__3__writeTo=console
# Add more rules to fine tuning the logging

# Use for troubleshooting. Having non-empty "enabled" array will run only the listed services. 
# Having the "disabled" filled in will run all services except listed.
# app__enabledStrategiesServices__0=
# app__disabledStrategiesServices__0=SS
# app__enabledExecutionServices__0=
# app__disabledExecutionServices__0=ES
# Add any number of dlls
app__strategyDllPaths__0=/strategies/Strategies.dll
# MDS is responsible for generating constant values. If you don't use constant values, set this to false.
app__enableMarketDataService=true
# Binance USDM Futures connector that connects to the /market stream (trades, candles)
app__enableBinanceUsdmMarketDataService=true
# Binance USDM Futures connector that connects to the /public stream (order books)
app__enableBinanceUsdmPublicMarketDataService=false

# Heartbeats are used to check expiration and activation of GTT and suspended orders
accounts-service__accounts-service__HeartbeatInterval=00:00:00:01
accounts-service__accounts-service__WritePerformanceMetrics=false
# Disabling this will stop accounts service saving the data persistently in the database
accounts-service__accounts-service__PersistEventsAndProjections=true
# When the end of day calculations are triggered
accounts-service__accounts-service__MtmUtcOffset=00:00:00:00
# Batch size used when populating the state of the local Accounts Service from the database in case of failover
accounts-service__accounts-service__HydrationBatchSize=100000
# When replaying events from WAL, disable logging
accounts-service__accounts-service__DisableLoggingOnReplay=true
# Directory when WAL files will be stored
accounts-service__wal__WorkingDirPath=/wal
accounts-service__wal__MaxNumberOfEventsInWal=65000
# When there is an empty WAL directory, try restore the state from the database
accounts-service__wal__TryRetrieveStateFromPersistentStorage=true
accounts-service__disruptors__InputDisruptorRingBufferSize=131072
# Since one incoming event may cause multiple events generated during the processing, have it at least twice big as the input disruptor.
# If during the startup the app hangs before finishing the processing of WAL, try temporary increasing this value.
accounts-service__disruptors__OutputDisruptorRingBufferSize=2097152

strategies-service__disruptors__InputDisruptorRingBufferSize=1024
strategies-service__disruptors__OutputDisruptorRingBufferSize=256
# When Strategies Service starts up and hydrates market data, IsHistory flag will be passed to strategies until (now - SkipProcessingOfHistoryBeforeFromNow) 
strategies-service__strategies-runner__SkipProcessingOfHistoryBeforeFromNow=00:00:02:00
# At each attempt, if historical candles are not hydrated completely during the startup, hydration will reiterate starting one month earlier 
strategies-service__strategies-runner__RequestBarAttempts=1
# If the strategy tries to send an order with zero volume, it's useful to have an exception during backtesting, but not in live environment
strategies-service__strategies-runner__ThrowOnZeroVolumeOrders=false
# When using virtual accounts, contract's MinSize / SizeStep are ignored and this value is used. Fraction = 100 means size step 0.01
strategies-service__strategies-runner__VirtualAccountSizeStepFraction=100
strategies-service__strategies-runner__WritePerformanceMetrics=false
strategies-service__strategies-service__WritePerformanceMetrics=false

execution-service__disruptors__InputDisruptorRingBufferSize=1024
execution-service__disruptors__OutputDisruptorRingBufferSize=256
execution-service__execution-service__WritePerformanceMetrics=false

mds__disruptors__InputDisruptorRingBufferSize=128
mds__disruptors__OutputDisruptorRingBufferSize=128

binance-usdm-mds__disruptors__InputDisruptorRingBufferSize=1024
binance-usdm-mds__disruptors__OutputDisruptorRingBufferSize=2048
binance-usdm-mds__client__DatasourceId=101
# Use the ID of the Binance's trading session from your static data
binance-usdm-mds__client__TradingSessionId=1051
binance-usdm-mds__client__Uri=wss://fstream.binance.com/market/stream
binance-usdm-mds__client__WritePerformanceMetrics=false
binance-usdm-mds__client__RestUri=https://fapi.binance.com/

binance-usdm-mds-ob__disruptors__InputDisruptorRingBufferSize=1024
binance-usdm-mds-ob__disruptors__OutputDisruptorRingBufferSize=2048
# Use the ID of the Binance's trading session from your static data
binance-usdm-mds-ob__client__DatasourceId=101
binance-usdm-mds-ob__client__TradingSessionId=1051
binance-usdm-mds-ob__client__Uri=wss://fstream.binance.com/public/stream
binance-usdm-mds-ob__client__WritePerformanceMetrics=false
binance-usdm-mds-ob__client__RestUri=https://fapi.binance.com/

# Set according to your installation
db.mds__Host=timescaledb
db.mds__Port=5432
db.mds__User=postgres
db.mds__Password=postgres
db.mds__Database=market_data
db.mds__CommandTimeoutSec=60
db.mds__ConnectionTimeoutSec=300
db.mds__MaxPoolSize=5
# db.mds__ConnectionStringExtras=Application Name=monolith;

# Set according to your installation
db.main__Host=timescaledb
db.main__Port=5432
db.main__User=postgres
db.main__Password=postgres
db.main__Database=main_v6_mono
db.main__CommandTimeoutSec=60
db.main__ConnectionTimeoutSec=300
db.main__MaxPoolSize=5
# db.main__ConnectionStringExtras=Application Name=monolith;
